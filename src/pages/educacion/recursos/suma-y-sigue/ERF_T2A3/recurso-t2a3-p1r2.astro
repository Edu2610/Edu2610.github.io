---
import Layout from '../../../../../layouts/Layout.astro';
// Asegúrate de que la ruta al Layout sea la correcta
---

<Layout titulo="Covariación Inversa">
    <div class="recurso-wrapper">
        <div class="card">
            <div class="interactive-container">
                
                <svg class="svg-layer svg-top" viewBox="0 0 700 160">
                    <defs>
                        <marker id="arrow-blue" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="4" markerHeight="4" orient="auto">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#2563eb" />
                        </marker>
                    </defs>
                    <path d="M 214 155 Q 268 80 322 155" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                    <path d="M 214 155 Q 322 10 430 155" fill="none" stroke="#2563eb" stroke-width="3" marker-end="url(#arrow-blue)" />
                    <path d="M 214 155 Q 376 -60 538 155" fill="none" stroke="#2563eb" stroke-width="4" marker-end="url(#arrow-blue)" />
                    <path d="M 214 155 Q 430 -130 646 155" fill="none" stroke="#2563eb" stroke-width="5" marker-end="url(#arrow-blue)" />
                </svg>

                <input type="text" id="top1" class="jump-input input-blue" style="left: 268px; top: -38px;" placeholder="· " autocomplete="off">
                <input type="text" id="top2" class="jump-input input-blue" style="left: 322px; top: -73px;" placeholder="· " autocomplete="off">
                <input type="text" id="top3" class="jump-input input-blue" style="left: 376px; top: -108px;" placeholder="· " autocomplete="off">
                <input type="text" id="top4" class="jump-input input-blue" style="left: 430px; top: -143px;" placeholder="· " autocomplete="off">

                <table>
                    <colgroup>
                        <col style="width: 160px;">
                        <col style="width: 108px;">
                        <col style="width: 108px;">
                        <col style="width: 108px;">
                        <col style="width: 108px;">
                        <col style="width: 108px;">
                    </colgroup>
                    <tr>
                        <td class="col-header">Velocidad (km/h)</td>
                        <td>10</td>
                        <td>20</td>
                        <td>40</td>
                        <td>80</td>
                        <td>160</td>
                    </tr>
                    <tr>
                        <td class="col-header">Tiempo (h)</td>
                        <td>10</td>
                        <td>5</td>
                        <td>2,5</td>
                        <td>1,25</td>
                        <td>0,625</td>
                    </tr>
                </table>

                <svg class="svg-layer svg-bottom" viewBox="0 0 700 160">
                    <defs>
                        <marker id="arrow-red" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="4" markerHeight="4" orient="auto">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#d32f2f" />
                        </marker>
                    </defs>
                    <path d="M 214 5 Q 268 80 322 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                    <path d="M 214 5 Q 322 150 430 5" fill="none" stroke="#d32f2f" stroke-width="3" marker-end="url(#arrow-red)" />
                    <path d="M 214 5 Q 376 220 538 5" fill="none" stroke="#d32f2f" stroke-width="4" marker-end="url(#arrow-red)" />
                    <path d="M 214 5 Q 430 290 646 5" fill="none" stroke="#d32f2f" stroke-width="5" marker-end="url(#arrow-red)" />
                </svg>

                <input type="text" id="bot1" class="jump-input input-red" style="left: 268px; bottom: -73px;" placeholder="÷ " autocomplete="off">
                <input type="text" id="bot2" class="jump-input input-red" style="left: 322px; bottom: -108px;" placeholder="÷ " autocomplete="off">
                <input type="text" id="bot3" class="jump-input input-red" style="left: 376px; bottom: -143px;" placeholder="÷ " autocomplete="off">
                <input type="text" id="bot4" class="jump-input input-red" style="left: 430px; bottom: -178px;" placeholder="÷ " autocomplete="off">

            </div>

            <button id="btn-verify" class="btn-verify">Verificar Respuesta</button>
            <div id="feedback" class="feedback-text"></div>
        </div>
    </div>
</Layout>

<style>
    .recurso-wrapper {
        font-family: 'Inter', system-ui, sans-serif;
        background: #f8fafc;
        display: flex;
        justify-content: center;
        padding: 40px 20px;
        width: 100%;
    }

    .card {
        background: white;
        padding: 40px 20px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        max-width: 750px;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .interactive-container {
        width: 700px;
        position: relative;
        margin-top: 140px; 
        margin-bottom: 180px; 
    }

    table {
        width: 700px;
        border-collapse: collapse;
        table-layout: fixed;
        position: relative;
        z-index: 1;
        margin: 0;
    }

    td {
        border: 1px solid #475569;
        height: 60px;
        text-align: center;
        vertical-align: middle;
        font-size: 1.1rem;
        font-weight: 600;
        color: #1e293b;
        box-sizing: border-box;
    }

    .col-header {
        background-color: #f1f5f9;
        font-weight: 700;
        text-align: right;
        padding-right: 15px;
    }

    .jump-input {
        position: absolute;
        width: 48px;
        height: 28px;
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        text-align: center;
        border: 2px solid #cbd5e1;
        border-radius: 6px;
        background: #ffffff;
        transition: all 0.2s;
        outline: none;
        z-index: 10;
        transform: translate(-50%, -50%); 
    }

    .jump-input::placeholder { color: #94a3b8; opacity: 0.6; }
    .jump-input:focus { box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15); }
    
    .input-blue { color: #2563eb; }
    .input-blue:focus { border-color: #2563eb; }
    
    .input-red { color: #d32f2f; }
    .input-red:focus { border-color: #d32f2f; }

    .correct { background-color: #ecfdf5 !important; border-color: #10b981 !important; color: #047857 !important; }
    .incorrect { background-color: #fef2f2 !important; border-color: #ef4444 !important; color: #b91c1c !important; }

    .btn-verify {
        padding: 12px 30px;
        margin-top : 10px;
        border: none;
        border-radius: 8px;
        background: #0f172a;
        color: white;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
        position: relative;
        z-index: 20;
    }

    .btn-verify:hover:not(:disabled) { background: #334155; transform: translateY(-2px); }
    .btn-verify:disabled { background: #cbd5e1; cursor: not-allowed; color: #f8fafc; }

    .feedback-text {
        margin-top: 15px;
        font-size: 0.95rem;
        font-weight: 600;
        min-height: 20px;
        text-align: center;
        max-width: 650px;
        line-height: 1.5;
    }

    .svg-layer {
        position: absolute;
        left: 0;
        width: 100%;
        pointer-events: none; 
        overflow: visible;
    }
    
    .svg-top { top: -160px; height: 160px; }
    .svg-bottom { bottom: -160px; height: 160px; }
</style>

<script>
    const setupVariacionAuto = () => {
        const correctAnswers: Record<string, string> = {
            top1: "· 2", top2: "· 4", top3: "· 8", top4: "· 16",
            bot1: "÷ 2", bot2: "÷ 4", bot3: "÷ 8", bot4: "÷ 16"
        };

        let estadoSaltos: Record<string, string> = {};
        const inputIds = Object.keys(correctAnswers);

        inputIds.forEach(id => {
            estadoSaltos[id] = "";
        });

        const btnVerify = document.getElementById('btn-verify') as HTMLButtonElement | null;
        const feedback = document.getElementById('feedback') as HTMLElement | null;

        if (!btnVerify || !feedback) return;

        inputIds.forEach(id => {
            const input = document.getElementById(id) as HTMLInputElement | null;
            if (!input) return;

            const newClone = input.cloneNode(true) as HTMLInputElement;
            input.parentNode?.replaceChild(newClone, input);

            newClone.addEventListener('input', (e) => {
                const target = e.target as HTMLInputElement;
                const isTop = id.startsWith('top');
                const prefix = isTop ? '· ' : '÷ ';
                
                let rawNumbers = target.value.replace(/[^0-9,.]/g, '');
                
                if (rawNumbers.length > 0) {
                    target.value = prefix + rawNumbers;
                } else {
                    target.value = ''; 
                }
                
                estadoSaltos[id] = target.value;
            });
        });

        const newBtnVerify = btnVerify.cloneNode(true) as HTMLButtonElement;
        btnVerify.parentNode?.replaceChild(newBtnVerify, btnVerify);

        newBtnVerify.addEventListener('click', () => {
            let correctCount = 0;

            inputIds.forEach(id => {
                const input = document.getElementById(id) as HTMLInputElement | null;
                if (!input) return;

                const userVal = estadoSaltos[id].trim();
                const correctVal = correctAnswers[id];

                input.disabled = true;

                if (userVal === correctVal) {
                    input.classList.add('correct');
                    correctCount++;
                } else {
                    input.classList.add('incorrect');
                    input.value = correctVal; 
                }
            });

            if (correctCount === inputIds.length) {
                feedback.style.color = "#047857";
                feedback.innerHTML = "¡Excelente! Has demostrado que <strong>si multiplicamos</strong> la velocidad (x) por un factor, el tiempo (y) <strong>se divide por ese mismo factor</strong>. A esto se le conoce como covariación inversamente proporcional.";
            } else {
                feedback.style.color = "#b91c1c";
                feedback.innerHTML = "Hay errores. Recuerda que los saltos se cuentan <strong>desde la columna base (10)</strong> hasta el valor de la casilla actual. Ej: de 10 a 80 el factor es · 8.";
            }

            newBtnVerify.disabled = true;
        });

        // Integración JSInput API de edX
        (window as any).getGrade = () => JSON.stringify(estadoSaltos);
        (window as any).getState = () => JSON.stringify(estadoSaltos);
        (window as any).setState = (stateStr: string) => {
            if (!stateStr) return;
            try {
                estadoSaltos = JSON.parse(stateStr);
                inputIds.forEach(id => {
                    if (estadoSaltos[id] !== "") {
                        const input = document.getElementById(id) as HTMLInputElement | null;
                        if (input) input.value = estadoSaltos[id];
                    }
                });
            } catch(e) {
                console.error("Error restaurando estado en edX", e);
            }
        };
    };

    document.addEventListener('DOMContentLoaded', setupVariacionAuto);
    document.addEventListener('astro:page-load', setupVariacionAuto);
</script>
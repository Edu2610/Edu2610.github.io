---
import Layout from '../../../../layouts/Layout.astro';
// Asegúrate de que la ruta al Layout sea la correcta
---

<Layout titulo="Explorador de Variación">
    <script is:inline src="https://cdn.plot.ly/plotly-2.24.1.min.js"></script>

    <div class="recurso-wrapper">
        <div class="card">
            <div class="header-text">
                <h3>Relación entre Puntos y Variación</h3>
                <p>Mueve los deslizadores para observar la compensación exacta entre los bidones.</p>
            </div>
            
            <div class="controls">
                <div class="slider-group">
                    <label>Punto A (x): <span id="valA" class="label-val">2.0</span></label>
                    <input type="range" id="slideA" min="0" max="12" step="0.3" value="2">
                </div>
                <div class="slider-group">
                    <label>Punto B (x): <span id="valB" class="label-val">6.0</span></label>
                    <input type="range" id="slideB" min="0" max="12" step="0.3" value="6">
                </div>
            </div>

            <div id="plot"></div>

            <div class="info-box">
                <strong>Análisis del Triángulo:</strong>
                Mientras <span class="text-blue">x varía <span id="dx">4.0</span></span> unidades, 
                <span class="text-red">y varía exactamente <span id="dy">4.0</span></span> unidades en sentido opuesto.
            </div>
        </div>
    </div>
</Layout>

<style>
    .recurso-wrapper {
        font-family: 'Inter', sans-serif;
        display: flex;
        justify-content: center;
        padding: 40px 20px;
        width: 100%;
        background-color: #f8fafc;
    }

    .card {
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        max-width: 850px;
        width: 100%;
    }

    .header-text { margin-bottom: 20px; text-align: center; }
    .header-text h3 { color: #d32f2f; margin: 0 0 5px 0; font-size: 1.5rem; }
    .header-text p { color: #64748b; font-size: 0.95rem; margin: 0; }

    .controls {
        display: flex;
        gap: 30px;
        background: #f1f5f9;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 15px;
        align-items: center;
        justify-content: space-around;
    }

    @media (max-width: 600px) {
        .controls { flex-direction: column; gap: 15px; }
    }

    .slider-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex-grow: 1;
        width: 100%;
    }

    .slider-group label { color: #475569; font-size: 0.95rem; }
    .label-val { font-weight: 800; color: #1e293b; }
    
    input[type=range] { width: 100%; cursor: pointer; }

    #plot { width: 100%; height: 550px; }

    .info-box {
        border-left: 4px solid #d32f2f;
        background: #fff1f2;
        padding: 15px 20px;
        font-size: 1rem;
        margin-top: 15px;
        border-radius: 4px;
        color: #1e293b;
    }

    .text-blue { color: #2563eb; font-weight: 600; }
    .text-red { color: #d32f2f; font-weight: 600; }
</style>

<script>
    declare const Plotly: any;

    const setupTriangulos = () => {
        const slideA = document.getElementById('slideA') as HTMLInputElement | null;
        const slideB = document.getElementById('slideB') as HTMLInputElement | null;
        const valA = document.getElementById('valA') as HTMLElement | null;
        const valB = document.getElementById('valB') as HTMLElement | null;
        const dxText = document.getElementById('dx') as HTMLElement | null;
        const dyText = document.getElementById('dy') as HTMLElement | null;
        const plotDiv = document.getElementById('plot') as HTMLElement | null;

        if (!slideA || !slideB || !valA || !valB || !dxText || !dyText || !plotDiv) return;

        function update() {
            const x1 = parseFloat(slideA!.value);
            const x2 = parseFloat(slideB!.value);
            const y1 = 12 - x1;
            const y2 = 12 - x2;

            valA!.innerText = x1.toFixed(1);
            valB!.innerText = x2.toFixed(1);
            
            const deltaX = x2 - x1;
            const deltaY = y2 - y1;
            dxText!.innerText = Math.abs(deltaX).toFixed(1);
            dyText!.innerText = Math.abs(deltaY).toFixed(1);

            const traceLine = {
                x: [0, 12], y: [12, 0],
                mode: 'lines', name: 'Recta',
                line: { color: '#94a3b8', width: 2, dash: 'dot' },
                hoverinfo: 'skip'
            };

            const triangle = {
                x: [x1, x2, x2],
                y: [y1, y1, y2],
                mode: 'lines',
                fill: 'toself',
                fillcolor: 'rgba(211, 47, 47, 0.1)',
                line: { color: '#d32f2f', width: 3 },
                name: 'Variación',
                hoverinfo: 'skip'
            };

            const points = {
                x: [x1, x2], y: [y1, y2],
                mode: 'markers+text',
                marker: { size: 12, color: '#1e293b' },
                text: [`A(${x1.toFixed(1)}, ${y1.toFixed(1)})`, `B(${x2.toFixed(1)}, ${y2.toFixed(1)})`],
                textposition: 'top center',
                name: 'Puntos',
                hoverinfo: 'none'
            };

            const layout = {
                xaxis: { title: 'Litros en Bidón B (x)', range: [-0.5, 12.5], dtick: 1, gridcolor: '#e2e8f0' },
                yaxis: { 
                    title: 'Litros en Bidón A (y)', 
                    range: [-0.5, 12.5], 
                    dtick: 1, 
                    gridcolor: '#e2e8f0',
                    scaleanchor: "x", 
                    scaleratio: 1 
                },
                showlegend: false,
                margin: { t: 30, b: 40, l: 50, r: 20 },
                hovermode: false,
                annotations: [
                    {
                        x: (x1 + x2) / 2,
                        y: y1 + 0.7,
                        text: `Δx = ${deltaX.toFixed(1)}`,
                        showarrow: false,
                        font: { color: '#2563eb', weight: 'bold' },
                        bgcolor: 'rgba(255,255,255,0.8)'
                    },
                    {
                        x: x2 + 1,
                        y: (y1 + y2) / 2,
                        text: `Δy = ${deltaY.toFixed(1)}`,
                        showarrow: false,
                        font: { color: '#d32f2f', weight: 'bold' },
                        bgcolor: 'rgba(255,255,255,0.8)'
                    }
                ]
            };

            if (typeof Plotly !== 'undefined') {
                Plotly.react('plot', [traceLine, triangle, points], layout);
            }
        }

        // Clonar sliders para limpiar listeners (View Transitions)
        const nSlideA = slideA.cloneNode(true) as HTMLInputElement;
        const nSlideB = slideB.cloneNode(true) as HTMLInputElement;
        
        slideA.parentNode?.replaceChild(nSlideA, slideA);
        slideB.parentNode?.replaceChild(nSlideB, slideB);

        // Sistema de carga segura (Polling)
        const initPlot = () => {
            if (typeof Plotly !== 'undefined') {
                update();
            } else {
                plotDiv.innerHTML = "<p style='text-align:center; color:#64748b; margin-top:100px;'>Cargando motor gráfico...</p>";
                const checkPlotly = setInterval(() => {
                    if (typeof Plotly !== 'undefined') {
                        clearInterval(checkPlotly);
                        plotDiv.innerHTML = "";
                        update();
                    }
                }, 200);
            }
        };

        // Listeners en los nodos clonados
        nSlideA.addEventListener('input', update);
        nSlideB.addEventListener('input', update);

        initPlot();
    };

    document.addEventListener('DOMContentLoaded', setupTriangulos);
    document.addEventListener('astro:page-load', setupTriangulos);
</script>
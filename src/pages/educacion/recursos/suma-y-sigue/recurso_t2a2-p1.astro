---
import Layout from '../../../../layouts/Layout.astro';
// Asegúrate de que la ruta al Layout sea la correcta según la ubicación de este archivo
---

<Layout titulo="Tabla de Variación Constante">
    <div class="recurso-wrapper">
        <div class="card">
            <div class="header-text">
                <h3></h3>
                <p>Escribe el valor del salto constante entre cada casilla (+1, -2, etc.).</p>
            </div>

            <div class="interactive-container">
                
                <svg class="svg-layer svg-top" viewBox="0 0 700 40">
                    <defs>
                        <marker id="arrow-blue" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#2563eb" />
                        </marker>
                    </defs>
                    <path d="M 225 35 Q 260 -10 295 35" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                    <path d="M 335 35 Q 370 -10 405 35" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                    <path d="M 445 35 Q 480 -10 515 35" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                    <path d="M 555 35 Q 590 -10 625 35" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                </svg>

                <input type="text" id="top1" class="jump-input input-blue" style="left: 260px; top: -55px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="top2" class="jump-input input-blue" style="left: 370px; top: -55px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="top3" class="jump-input input-blue" style="left: 480px; top: -55px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="top4" class="jump-input input-blue" style="left: 590px; top: -55px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">

                <table>
                    <tr>
                        <td class="col-header">Bidón B</td>
                        <td>0</td>
                        <td>1</td>
                        <td>2</td>
                        <td>3</td>
                        <td>4</td>
                    </tr>
                    <tr>
                        <td class="col-header">Bidón A</td>
                        <td>12</td>
                        <td>11</td>
                        <td>10</td>
                        <td>9</td>
                        <td>8</td>
                    </tr>
                </table>

                <svg class="svg-layer svg-bottom" viewBox="0 0 700 40" style="overflow: visible;">
                    <defs>
                        <marker id="arrow-red" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#d32f2f" />
                        </marker>
                    </defs>
                    <path d="M 225 5 Q 260 50 295 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                    <path d="M 335 5 Q 370 50 405 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                    <path d="M 445 5 Q 480 50 515 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                    <path d="M 555 5 Q 590 50 625 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                </svg>

                <input type="text" id="bot1" class="jump-input input-red" style="left: 260px; bottom: -65px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="bot2" class="jump-input input-red" style="left: 370px; bottom: -65px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="bot3" class="jump-input input-red" style="left: 480px; bottom: -65px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="bot4" class="jump-input input-red" style="left: 590px; bottom: -65px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">

            </div>

            <button id="btn-verify" class="btn-verify">Verificar respuesta</button>
            <div id="feedback" class="feedback-text"></div>
        </div>
    </div>
</Layout>

<style>
    /* El estilo del body original se traslada a este wrapper */
    .recurso-wrapper {
        font-family: 'Inter', sans-serif;
        display: flex;
        justify-content: center;
        padding: 40px 20px;
        width: 100%;
    }

    .card {
        background: white;
        padding: 40px 20px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        max-width: 800px;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .header-text { text-align: center; margin-bottom: 20px; }
    .header-text h3 { color: #0f172a; margin: 0 0 5px 0; font-size: 1.25rem; }
    .header-text p { color: #64748b; font-size: 0.9rem; margin: 0; }

    .interactive-container {
        width: 700px;
        position: relative;
        margin-top: 70px; 
        margin-bottom: 70px; 
    }

    table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
        position: relative;
        z-index: 1;
    }

    td {
        border: 1px solid #475569;
        height: 60px;
        text-align: center;
        vertical-align: middle;
        font-size: 1.2rem;
        font-weight: 600;
        color: #1e293b;
    }

    .col-header {
        width: 150px;
        background-color: #f1f5f9;
        font-weight: 700;
        text-align: right;
        padding-right: 15px;
    }

    .jump-input {
        position: absolute;
        width: 44px;
        height: 28px;
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        text-align: center;
        border: 2px solid #cbd5e1;
        border-radius: 6px;
        background: #ffffff;
        transition: all 0.2s;
        outline: none;
        z-index: 10;
        transform: translate(-50%, -50%); 
    }

    .jump-input:focus { box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15); }
    .input-blue { color: #2563eb; }
    .input-blue:focus { border-color: #2563eb; }
    .input-red { color: #d32f2f; }
    .input-red:focus { border-color: #d32f2f; }

    .jump-input.correct { background-color: #ecfdf5; border-color: #10b981; color: #047857; }
    .jump-input.incorrect { background-color: #fef2f2; border-color: #ef4444; color: #b91c1c; }

    .btn-verify {
        padding: 12px 30px;
        margin-top: 10px;
        border: none;
        border-radius: 8px;
        background: #0f172a;
        color: white;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
    }

    .btn-verify:hover:not(:disabled) { background: #334155; transform: translateY(-2px); }
    .btn-verify:disabled { background: #cbd5e1; cursor: not-allowed; color: #f8fafc; }

    .feedback-text {
        margin-top: 15px;
        font-size: 0.9rem;
        font-weight: 600;
        min-height: 20px;
    }

    .svg-layer {
        position: absolute;
        left: 0;
        width: 100%;
        pointer-events: none; 
    }
    .svg-top { top: -40px; height: 40px; }
    .svg-bottom { bottom: -40px; height: 40px; }
</style>

<script>
    const setupTabla = () => {
        const correctAnswers: Record<string, string> = {
            top1: "+1", top2: "+1", top3: "+1", top4: "+1",
            bot1: "-1", bot2: "-1", bot3: "-1", bot4: "-1"
        };

        let estadoSaltos: Record<string, string> = {
            top1: "", top2: "", top3: "", top4: "",
            bot1: "", bot2: "", bot3: "", bot4: ""
        };

        const btnVerify = document.getElementById('btn-verify') as HTMLButtonElement | null;
        const feedback = document.getElementById('feedback') as HTMLElement | null;
        const inputIds = Object.keys(correctAnswers);

        if (!btnVerify || !feedback) return;

        function formatAnswer(val: string, expected: string) {
            let clean = val.trim();
            if (expected === "+1" && clean === "1") return "+1";
            return clean;
        }

        inputIds.forEach(id => {
            const input = document.getElementById(id) as HTMLInputElement | null;
            if (!input) return;

            // Limpieza de eventos para View Transitions de Astro
            const newClone = input.cloneNode(true) as HTMLInputElement;
            input.parentNode?.replaceChild(newClone, input);

            newClone.addEventListener('input', (e) => {
                estadoSaltos[id] = (e.target as HTMLInputElement).value;
            });
        });

        const newBtnVerify = btnVerify.cloneNode(true) as HTMLButtonElement;
        btnVerify.parentNode?.replaceChild(newBtnVerify, btnVerify);

        newBtnVerify.addEventListener('click', () => {
            let correctCount = 0;

            inputIds.forEach(id => {
                const input = document.getElementById(id) as HTMLInputElement | null;
                if (!input) return;

                const userVal = formatAnswer(estadoSaltos[id], correctAnswers[id]);
                const correctVal = correctAnswers[id];

                input.disabled = true;

                if (userVal === correctVal) {
                    input.classList.add('correct');
                    correctCount++;
                } else {
                    input.classList.add('incorrect');
                    input.value = correctVal; 
                }
            });

            if (correctCount === inputIds.length) {
                feedback.style.color = "#047857";
                feedback.textContent = "¡Perfecto! Has identificado la variación constante en ambas variables.";
            } else {
                feedback.style.color = "#b91c1c";
                feedback.textContent = `Hay errores. Recuerda incluir el signo (+ o -) para indicar la dirección del cambio.`;
            }

            newBtnVerify.disabled = true;
        });

        // Exponer funciones a nivel global (window) para que el iframe de edX pueda leerlas
        (window as any).getGrade = () => JSON.stringify(estadoSaltos);
        (window as any).getState = () => JSON.stringify(estadoSaltos);
        (window as any).setState = (stateStr: string) => {
            if (!stateStr) return;
            try {
                estadoSaltos = JSON.parse(stateStr);
                inputIds.forEach(id => {
                    if (estadoSaltos[id] !== "") {
                        const input = document.getElementById(id) as HTMLInputElement | null;
                        if (input) input.value = estadoSaltos[id];
                    }
                });
            } catch(e) {
                console.error("Error restaurando estado en edX", e);
            }
        };
    };

    document.addEventListener('DOMContentLoaded', setupTabla);
    document.addEventListener('astro:page-load', setupTabla);
</script>
---
import Layout from '../../../../layouts/Layout.astro';
// Ajusta la ruta al Layout según tu estructura de carpetas
---

<Layout titulo="La doble recta numérica">
    <div class="recurso-wrapper">
        <div class="card">
            <div class="header-content">
                <h3>La doble recta numérica: volver a la unidad</h3>
                <p>Avanza por los pasos para descubrir cómo usar la tasa unitaria.</p>
            </div>
            
            <div class="controls">
                <button id="btn1" class="btn-step">Paso 1: Par conocido</button>
                <button id="btn2" class="btn-step" disabled>Paso 2: Valor unitario</button>
                <button id="btn3" class="btn-step" disabled>Paso 3: Multiplicar</button>
                <button id="btnReset" class="btn-reset">Reiniciar</button>
            </div>

            <div id="svg-container">
                <svg width="100%" height="100%" viewBox="0 0 800 350" preserveAspectRatio="xMidYMid meet">
                    <defs>
                        <marker id="arrow-blue" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#2563eb" />
                        </marker>
                        <marker id="arrow-red" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#d32f2f" />
                        </marker>
                    </defs>

                    <line x1="120" y1="120" x2="750" y2="120" stroke="#94a3b8" stroke-width="3" />
                    <line x1="120" y1="230" x2="750" y2="230" stroke="#94a3b8" stroke-width="3" />
                    
                    <text x="100" y="125" font-weight="bold" fill="#1e293b" text-anchor="end">Harina (x)</text>
                    <text x="100" y="235" font-weight="bold" fill="#1e293b" text-anchor="end">Azúcar (y)</text>

                    <line x1="150" y1="110" x2="150" y2="240" stroke="#cbd5e1" stroke-width="2" stroke-dasharray="4" />
                    <text x="150" y="100" text-anchor="middle" font-size="14">0</text>
                    <text x="150" y="260" text-anchor="middle" font-size="14">0</text>

                    <g id="g-step1" class="hidden">
                        <line x1="550" y1="110" x2="550" y2="240" stroke="#1e293b" stroke-width="2" stroke-dasharray="4" />
                        <circle cx="550" cy="120" r="6" fill="#1e293b" />
                        <circle cx="550" cy="230" r="6" fill="#1e293b" />
                        <text x="550" y="100" text-anchor="middle" font-weight="bold" font-size="16">3</text>
                        <text x="550" y="260" text-anchor="middle" font-weight="bold" font-size="16">2</text>
                    </g>

                    <g id="g-step2" class="hidden">
                        <line x1="283" y1="110" x2="283" y2="240" stroke="#059669" stroke-width="2" stroke-dasharray="4" />
                        <circle cx="283" cy="120" r="6" fill="#059669" />
                        <circle cx="283" cy="230" r="6" fill="#059669" />
                        <text x="283" y="100" text-anchor="middle" font-weight="bold" font-size="16" fill="#059669">1</text>
                        <text x="283" y="260" text-anchor="middle" font-weight="bold" font-size="16" fill="#059669">2/3</text>

                        <path d="M 540 100 Q 416 60 293 100" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                        <text x="416" y="75" text-anchor="middle" fill="#2563eb" font-weight="bold" font-size="14">÷ 3</text>

                        <path d="M 540 250 Q 416 290 293 250" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                        <text x="416" y="295" text-anchor="middle" fill="#d32f2f" font-weight="bold" font-size="14">÷ 3</text>
                    </g>

                    <g id="g-step3" class="hidden">
                        <line x1="603" y1="110" x2="603" y2="240" stroke="#9333ea" stroke-width="2" stroke-dasharray="4" />
                        <circle cx="603" cy="120" r="6" fill="#9333ea" />
                        <circle cx="603" cy="230" r="6" fill="#9333ea" />
                        <text x="603" y="100" text-anchor="middle" font-weight="bold" font-size="16" fill="#9333ea">3.4</text>
                        <text x="603" y="260" text-anchor="middle" font-weight="bold" font-size="16" fill="#9333ea">2.27</text>

                        <path d="M 283 85 Q 443 10 593 85" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                        <text x="443" y="20" text-anchor="middle" fill="#2563eb" font-weight="bold" font-size="14">× 3.4</text>

                        <path d="M 283 265 Q 443 340 593 265" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                        <text x="443" y="330" text-anchor="middle" fill="#d32f2f" font-weight="bold" font-size="14">× 3.4</text>
                    </g>
                </svg>
            </div>

            <div class="info-box" id="info-text">
                Selecciona "Paso 1" para comenzar.
            </div>
        </div>
    </div>
</Layout>

<style>
    .recurso-wrapper {
        font-family: 'Inter', system-ui, sans-serif;
        background-color: #f8fafc;
        display: flex;
        justify-content: center;
        padding: 40px 20px;
        width: 100%;
    }

    .card {
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        max-width: 800px;
        width: 100%;
    }

    .header-content h3 {
        color: #0f172a;
        margin-top: 0;
        text-align: center;
        font-size: 1.5rem;
    }

    .header-content p {
        font-size: 0.95rem;
        color: #64748b;
        text-align: center;
        margin-bottom: 25px;
    }

    .controls {
        display: flex;
        gap: 15px;
        background: #f1f5f9;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        flex-wrap: wrap;
        justify-content: center;
    }

    button {
        padding: 10px 20px;
        border: none;
        border-radius: 6px;
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-step { background: #2563eb; color: white; }
    .btn-step:hover:not(:disabled) { background: #1d4ed8; transform: translateY(-2px); }
    .btn-step:disabled { background: #cbd5e1; cursor: not-allowed; color: #64748b; transform: none; }

    .btn-reset { background: #ef4444; color: white; }
    .btn-reset:hover { background: #dc2626; transform: translateY(-2px); }

    #svg-container {
        width: 100%;
        height: 350px;
        position: relative;
    }

    text { font-family: 'Inter', system-ui, sans-serif; }

    .info-box {
        border-left: 4px solid #059669;
        background: #ecfdf5;
        padding: 15px 20px;
        font-size: 1rem;
        margin-top: 10px;
        border-radius: 4px;
        min-height: 40px;
        line-height: 1.5;
        color: #064e3b;
    }
    
    /* Clases para animación de SVG */
    :global(.hidden) { opacity: 0; pointer-events: none; }
    :global(.visible) { opacity: 1; transition: opacity 0.5s ease-in; }
</style>

<script>
    const setupDobleRecta = () => {
        const btn1 = document.getElementById('btn1') as HTMLButtonElement | null;
        const btn2 = document.getElementById('btn2') as HTMLButtonElement | null;
        const btn3 = document.getElementById('btn3') as HTMLButtonElement | null;
        const btnReset = document.getElementById('btnReset') as HTMLButtonElement | null;
        
        const step1 = document.getElementById('g-step1');
        const step2 = document.getElementById('g-step2');
        const step3 = document.getElementById('g-step3');
        const infoText = document.getElementById('info-text');

        if (!btn1 || !btn2 || !btn3 || !btnReset || !step1 || !step2 || !step3 || !infoText) return;

        // Clonar botones para limpiar listeners previos de Astro View Transitions
        const nBtn1 = btn1.cloneNode(true) as HTMLButtonElement;
        const nBtn2 = btn2.cloneNode(true) as HTMLButtonElement;
        const nBtn3 = btn3.cloneNode(true) as HTMLButtonElement;
        const nBtnR = btnReset.cloneNode(true) as HTMLButtonElement;

        btn1.parentNode?.replaceChild(nBtn1, btn1);
        btn2.parentNode?.replaceChild(nBtn2, btn2);
        btn3.parentNode?.replaceChild(nBtn3, btn3);
        btnReset.parentNode?.replaceChild(nBtnR, btnReset);

        // Estado inicial de reinicio
        const resetState = () => {
            step1.classList.replace('visible', 'hidden');
            step2.classList.replace('visible', 'hidden');
            step3.classList.replace('visible', 'hidden');
            
            nBtn1.disabled = false;
            nBtn2.disabled = true;
            nBtn3.disabled = true;
            
            infoText.innerHTML = "Selecciona 'Paso 1' para comenzar.";
        };

        // Forzar limpieza al montar el componente
        resetState();

        // Asignación de eventos
        nBtn1.addEventListener('click', () => {
            step1.classList.replace('hidden', 'visible');
            nBtn1.disabled = true;
            nBtn2.disabled = false;
            infoText.innerHTML = "<strong>Paso 1:</strong> Ubicamos el par base conocido de la receta. Sabemos que 3 tazas de harina requieren 2 tazas de azúcar.";
        });

        nBtn2.addEventListener('click', () => {
            step2.classList.replace('hidden', 'visible');
            nBtn2.disabled = true;
            nBtn3.disabled = false;
            infoText.innerHTML = "<strong>Paso 2:</strong> Calculamos el valor unitario. Dividimos ambas cantidades por 3. Ahora sabemos que 1 taza de harina requiere 2/3 de taza de azúcar.";
        });

        nBtn3.addEventListener('click', () => {
            step3.classList.replace('hidden', 'visible');
            nBtn3.disabled = true;
            infoText.innerHTML = "<strong>Paso 3:</strong> Multiplicamos el valor unitario por el factor objetivo (3,4). Al escalar la unidad base, evitamos el problema de que 3,4 no sea múltiplo de 3.";
        });

        nBtnR.addEventListener('click', resetState);
    };

    // Inicialización compatible con View Transitions
    document.addEventListener('DOMContentLoaded', setupDobleRecta);
    document.addEventListener('astro:page-load', setupDobleRecta);
</script>
---
import Layout from '../../../../layouts/Layout.astro';
// Ajusta la ruta al Layout según la ubicación real de este archivo
---

<Layout titulo="Proporcionalidad: Correspondencia">
    <div class="recurso-wrapper">
        <div class="card">
            <div class="main-content">
                <div class="panel-izquierdo">
                    <div class="maquina-coord" id="box-ecuacion">
                        y = <span>2/3</span> · <span style="color:var(--primary)" id="ecuacion-x">6</span>
                    </div>

                    <div class="maquina-coord" style="flex-direction: column; gap: 8px;">
                        <div style="font-family: 'Inter', system-ui, sans-serif; font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--text); opacity: 0.6; letter-spacing: 0.5px;">
                            Correspondencia
                        </div>
                        <div id="box-correspondencia" style="display: flex; justify-content: center; align-items: center; min-height: 25px; width: 100%;">
                            <span style="color:var(--primary)">x = 6</span>
                        </div>
                    </div>

                    <div class="caja-control">
                        <label>x: <span id="txt-x" style="color: var(--primary); font-size: 16px;">6</span></label>
                        <input type="range" id="slider-x" min="0" max="15" step="1" value="6">
                    </div>
                    <button id="btn-anim-corr" class="btn-accion">Animar ▶</button>
                    <button id="btn-limpiar-corr" class="btn-accion btn-limpiar">Limpiar</button>
                </div>

                <div class="panel-visor">
                    <svg id="lienzo" viewBox="0 0 550 450" preserveAspectRatio="xMidYMid meet">
                        <defs>
                            <marker id="head-cor" orient="auto" markerWidth="4" markerHeight="4" refX="3" refY="2">
                                <path d="M0,0 L4,2 L0,4 Z" fill="var(--machine)" />
                            </marker>
                        </defs>

                        <g id="capa-grilla"></g>
                        <line id="eje-x" class="eje" /> 
                        <line id="eje-y" class="eje" />  

                        <text id="lbl-o" text-anchor="end" class="eje-num">0</text>
                        <text id="lbl-ejex" text-anchor="end" class="eje-label">x →</text>
                        <text id="lbl-ejey" text-anchor="start" class="eje-label">y ↑</text>

                        <line id="recta-principal" class="recta-func" />
                        <g id="capa-animacion"></g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .recurso-wrapper {
        --primary: #D33C31;       
        --machine: #E87461;       
        --bg: #F4F4F2;            
        --text: #4A4A49;          
        --border: #D8D8D5;        
        
        font-family: 'Inter', system-ui, sans-serif;
        background-color: var(--bg);
        color: var(--text);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 20px;
        width: 100%;
        min-height: 100vh;
        box-sizing: border-box;
    }

    .card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(74, 74, 73, 0.08);
        border: 1px solid var(--border);
        width: 100%;
        max-width: 850px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .main-content { display: flex; height: 550px; }

    .panel-izquierdo {
        width: 340px; background: rgba(244, 244, 242, 0.5); border-right: 1px solid var(--border);
        padding: 25px; display: flex; flex-direction: column; gap: 20px;
        box-sizing: border-box;
    }

    .caja-control {
        background: white; padding: 15px; border-radius: 8px;
        border: 1px solid var(--border); display: flex; flex-direction: column; gap: 12px;
        border-left: 4px solid var(--machine);
    }

    .caja-control label { font-weight: 700; font-size: 13px; color: var(--text); text-transform: uppercase; }
    
    input[type="range"] { 
        width: 100%; cursor: pointer; height: 6px; background: var(--border); border-radius: 3px; outline: none; -webkit-appearance: none;
    }
    input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%;
        background: var(--primary); cursor: pointer; box-shadow: 0 2px 4px rgba(74,74,73,0.2);
    }

    .btn-accion {
        padding: 12px; border: none; border-radius: 8px; font-weight: 600; font-size: 14px;
        cursor: pointer; transition: all 0.2s; color: white; width: 100%; background: var(--machine);
    }
    .btn-accion:hover:not(:disabled) { filter: brightness(1.1); transform: translateY(-2px); }
    .btn-accion:disabled { background: var(--border) !important; cursor: not-allowed; transform: none; color: white; }

    .btn-limpiar { background: var(--text); margin-top: auto; }

    .maquina-coord {
        background: white; border: 2px solid var(--border); border-radius: 10px;
        padding: 15px 10px; text-align: center; font-family: 'Courier New', monospace;
        font-size: 20px; font-weight: 700; color: var(--text);
        box-shadow: inset 0 2px 10px rgba(74,74,73,0.03); min-height: 60px;
        display: flex; justify-content: center; align-items: center;
    }

    #box-ecuacion {
        font-size: 18px;
        min-height: 40px;
        padding: 10px;
        background: rgba(255, 255, 255, 0.7);
    }

    .panel-visor {
        flex-grow: 1; background: white; padding: 20px; display: flex; justify-content: center; align-items: center;
    }
    svg { width: 100%; max-width: 550px; height: 100%; overflow: visible; }
    
    .eje { stroke: var(--text); stroke-width: 2.5; stroke-linecap: square; }
    .recta-func { stroke: var(--text); stroke-width: 2; stroke-dasharray: 4; opacity: 0.4; }

    /* Animaciones CSS del recuadro */
    :global(.anim-flecha) {
        display: inline-block; max-width: 0; opacity: 0; overflow: hidden;
        white-space: nowrap; vertical-align: middle; transition: max-width 0.4s ease, opacity 0.3s ease;
    }
    :global(.anim-flecha.activa) { max-width: 50px; opacity: 1; }
    
    :global(.anim-y) {
        opacity: 0; transform: translateX(-10px); display: inline-block; transition: all 0.3s ease 0.1s;
    }
    :global(.anim-y.activa) { opacity: 1; transform: translateX(0); }

    /* Clases SVG inyectadas */
    :global(.grilla-menor) { stroke: var(--bg); stroke-width: 1; }
    :global(.grilla-mayor) { stroke: var(--border); stroke-width: 1.5; }
    :global(.eje-num) { font-size: 12px; fill: var(--text); font-weight: 500; }
    :global(.eje-label) { font-size: 13px; font-weight: 700; fill: var(--text); }
    
    :global(.lbl-mat) { 
        font-size: 14px; font-weight: 600; paint-order: stroke fill; stroke: var(--bg); stroke-width: 3px; 
    }
    :global(.punto) { fill: var(--text); stroke: white; stroke-width: 2; }

    @media (max-width: 768px) {
        .main-content { flex-direction: column; height: auto; }
        .panel-izquierdo { width: 100%; border-right: none; border-bottom: 1px solid var(--border); }
    }
</style>

<script>
    const setupRecurso = () => {
        const xMax = 16, yMax = 12;
        // Escala 1:1 estricta: 28px por unidad en ambos ejes. Da un buen tamaño.
        const cW = xMax * 28; // 448
        const cH = yMax * 28; // 336
        const mX = 50, mY = 40; 
        const baseLine = mY + cH;

        const mapX = (x: number) => mX + (x / xMax) * cW;
        const mapY = (y: number) => baseLine - (y / yMax) * cH;

        const capaAnim = document.getElementById('capa-animacion');
        const sliderX = document.getElementById('slider-x') as HTMLInputElement;
        const btnAnimCorr = document.getElementById('btn-anim-corr') as HTMLButtonElement;
        const btnLimpiarCorr = document.getElementById('btn-limpiar-corr') as HTMLButtonElement;
        const boxCorr = document.getElementById('box-correspondencia');

        let animId: number | null = null;
        let resolucionActual: ((value: any) => void) | null = null; 

        if (!capaAnim) return;

        function configurarPlano() {
            document.getElementById('eje-x')?.setAttribute('x1', mX.toString());
            document.getElementById('eje-x')?.setAttribute('y1', baseLine.toString());
            document.getElementById('eje-x')?.setAttribute('x2', (mX + cW + 20).toString());
            document.getElementById('eje-x')?.setAttribute('y2', baseLine.toString());

            document.getElementById('eje-y')?.setAttribute('x1', mX.toString());
            document.getElementById('eje-y')?.setAttribute('y1', baseLine.toString());
            document.getElementById('eje-y')?.setAttribute('x2', mX.toString());
            document.getElementById('eje-y')?.setAttribute('y2', (mY - 10).toString());

            document.getElementById('lbl-o')?.setAttribute('x', (mX - 8).toString());
            document.getElementById('lbl-o')?.setAttribute('y', (baseLine + 15).toString());
            document.getElementById('lbl-ejex')?.setAttribute('x', (mX + cW + 20).toString());
            document.getElementById('lbl-ejex')?.setAttribute('y', (baseLine + 35).toString());
            document.getElementById('lbl-ejey')?.setAttribute('x', mX.toString());
            document.getElementById('lbl-ejey')?.setAttribute('y', (mY - 20).toString());

            const grilla = document.getElementById('capa-grilla');
            if (grilla) {
                grilla.innerHTML = '';
                // Se marca cada 2 unidades para evitar la distorsión visual de rectángulos de 2x3
                for(let i=1; i<=xMax; i++) {
                    let px = mapX(i);
                    grilla.innerHTML += `<line x1="${px}" y1="${baseLine}" x2="${px}" y2="${mY}" class="${i%2===0 ? 'grilla-mayor' : 'grilla-menor'}" />`;
                    if(i%2===0) grilla.innerHTML += `<text x="${px}" y="${baseLine+16}" text-anchor="middle" class="eje-num">${i}</text>`;
                }
                for(let j=1; j<=yMax; j++) {
                    let py = mapY(j);
                    grilla.innerHTML += `<line x1="${mX}" y1="${py}" x2="${mX+cW}" y2="${py}" class="${j%2===0 ? 'grilla-mayor' : 'grilla-menor'}" />`;
                    if(j%2===0) grilla.innerHTML += `<text x="${mX-8}" y="${py+4}" text-anchor="end" class="eje-num">${j}</text>`;
                }
            }

            document.getElementById('recta-principal')?.setAttribute('x1', mapX(0).toString());
            document.getElementById('recta-principal')?.setAttribute('y1', mapY(0).toString());
            document.getElementById('recta-principal')?.setAttribute('x2', mapX(15).toString());
            document.getElementById('recta-principal')?.setAttribute('y2', mapY(10).toString());
        }

        function restaurarMedio() {
            if (!sliderX || !boxCorr) return;
            const val = sliderX.value;
            boxCorr.innerHTML = `<span style="color:var(--primary)">x = ${val}</span>`;
        }

        function limpiarVisor() {
            if(animId) cancelAnimationFrame(animId);
            if(resolucionActual) resolucionActual({ interrumpido: true });
            if(capaAnim) capaAnim.innerHTML = '';
            if(btnAnimCorr) btnAnimCorr.disabled = false;
            if(sliderX) sliderX.disabled = false;
            restaurarMedio();
        }

        function dibujarVector(x1: number, y1: number, x2: number, y2: number, color: string, marker: string | null, duracion: number, isDashed = false): Promise<any> {
            return new Promise(resolve => {
                resolucionActual = resolve;
                const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
                line.setAttribute('x1', x1.toString()); line.setAttribute('y1', y1.toString());
                line.setAttribute('x2', x1.toString()); line.setAttribute('y2', y1.toString());
                line.setAttribute('stroke', color);
                line.setAttribute('stroke-width', '3');
                line.setAttribute('stroke-linecap', 'round');
                
                if (marker) {
                    line.setAttribute('marker-end', `url(#${marker})`);
                }
                if (isDashed) {
                    line.setAttribute('stroke-dasharray', '6, 5');
                }
                
                capaAnim?.appendChild(line);

                let start: number | null = null;
                function step(ts: number) {
                    if(!start) start = ts;
                    let p = Math.min((ts - start) / duracion, 1);
                    let ease = 1 - Math.pow(1 - p, 3);
                    
                    line.setAttribute('x2', (x1 + (x2 - x1) * ease).toString());
                    line.setAttribute('y2', (y1 + (y2 - y1) * ease).toString());
                    
                    if(p < 1) {
                        animId = requestAnimationFrame(step);
                    } else {
                        resolucionActual = null;
                        resolve({ interrumpido: false });
                    }
                }
                animId = requestAnimationFrame(step);
            });
        }

        function agregarPunto(x: number, y: number, color: string) {
            const pt = document.createElementNS("http://www.w3.org/2000/svg", "circle");
            pt.setAttribute('cx', x.toString()); pt.setAttribute('cy', y.toString());
            pt.setAttribute('r', '5');
            pt.setAttribute('fill', color);
            pt.setAttribute('stroke', 'var(--bg)');
            pt.setAttribute('stroke-width', '2');
            capaAnim?.appendChild(pt);
        }

        function agregarTexto(x: number, y: number, texto: string, color: string, anchor="middle") {
            const txt = document.createElementNS("http://www.w3.org/2000/svg", "text");
            txt.setAttribute('x', x.toString()); txt.setAttribute('y', y.toString());
            txt.setAttribute('text-anchor', anchor);
            txt.setAttribute('class', 'lbl-mat');
            txt.style.fill = color;
            txt.textContent = texto;
            capaAnim?.appendChild(txt);
        }

        if (btnLimpiarCorr) {
            btnLimpiarCorr.addEventListener('click', limpiarVisor);
        }

        if (sliderX) {
            sliderX.addEventListener('input', (e) => {
                const val = (e.target as HTMLInputElement).value;
                const txtX = document.getElementById('txt-x');
                const ecuacionX = document.getElementById('ecuacion-x');
                
                if(txtX) txtX.textContent = val;
                if(ecuacionX) ecuacionX.textContent = val;
                restaurarMedio();
            });
        }

        if (btnAnimCorr) {
            btnAnimCorr.addEventListener('click', async () => {
                limpiarVisor();
                btnAnimCorr.disabled = true;
                if(sliderX) sliderX.disabled = true;

                const x = parseFloat(sliderX.value);
                const y = (2/3) * x;
                const colorMac = 'var(--machine)';
                
                if (boxCorr) {
                    boxCorr.innerHTML = `
                        <span style="color:var(--primary)">x = ${x}</span>
                        <span class="anim-flecha" id="box-arrow">&nbsp;⟶&nbsp;</span>
                        <span class="anim-y" id="box-y" style="color:var(--machine)">y = ${y.toFixed(1)}</span>
                    `;
                }
                
                let res1 = await dibujarVector(mapX(x), mapY(0), mapX(x), mapY(y), colorMac, null, 600, true);
                if(res1.interrumpido) return;
                
                agregarTexto(mapX(x) + 10, mapY(y/2) + 4, `x = ${x}`, colorMac, 'start');
                agregarPunto(mapX(x), mapY(y), colorMac);

                await new Promise(r => setTimeout(r, 200));

                let res2 = await dibujarVector(mapX(x), mapY(y), mapX(0), mapY(y), colorMac, 'head-cor', 600, true);
                if(res2.interrumpido) return;

                agregarTexto(mapX(x/2), mapY(y) - 12, `y = ${y.toFixed(1)}`, colorMac);

                document.getElementById('box-arrow')?.classList.add('activa');
                document.getElementById('box-y')?.classList.add('activa');

                btnAnimCorr.disabled = false;
                if(sliderX) sliderX.disabled = false;
            });
        }

        configurarPlano();

        // Integración edX
        (window as any).getGrade = () => JSON.stringify({ action: "explore" });
        (window as any).getState = () => JSON.stringify({ action: "explore" });
        (window as any).setState = () => {};
    };

    document.addEventListener('DOMContentLoaded', setupRecurso);
    document.addEventListener('astro:page-load', setupRecurso);
</script>
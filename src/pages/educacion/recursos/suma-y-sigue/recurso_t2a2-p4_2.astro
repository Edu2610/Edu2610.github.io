---
import Layout from '../../../../layouts/Layout.astro';
// Ajusta la ruta al Layout según la ubicación real de este archivo
---

<Layout titulo="Proporcionalidad: Covariación y Correspondencia">
    <div class="recurso-wrapper">
        <div class="card">
            <div class="header-bar">
                <div>
                    <h2 id="titulo-modo">Enfoque Covariacional</h2>
                    <p id="desc-modo">Escalamiento iterativo de las cantidades.</p>
                </div>
                <button id="btn-toggle" class="btn-toggle">Ver Correspondencia ⇄</button>
            </div>

            <div class="main-content">
                <div class="panel-izquierdo">
                    
                    <!-- MODO 1: COVARIACIÓN -->
                    <div id="modo-covariacion" class="modo-container active">
                        <div class="caja-control" style="border-left-color: var(--operator)">
                            <label>Factor de Escala (n): <span id="txt-factor" style="color: var(--operator); font-size: 16px;">× 4</span></label>
                            <input type="range" id="slider-factor" min="1" max="5" step="1" value="4">
                        </div>
                        <div class="info-box" style="border-left-color: var(--operator);">
                            <strong>Construcción Iterativa:</strong><br>
                            El factor multiplicativo repite el bloque base (Δx=3, Δy=2) una cantidad <strong>n</strong> de veces, acumulando los cambios en cada eje de manera secuencial.
                        </div>
                        <button id="btn-anim-cov" class="btn-accion" style="background: var(--operator)">Animar Escalamiento ▶</button>
                        <button id="btn-limpiar-cov" class="btn-accion btn-limpiar">Limpiar Gráfico</button>
                    </div>

                    <!-- MODO 2: CORRESPONDENCIA -->
                    <div id="modo-correspondencia" class="modo-container">
                        <div class="maquina-coord" id="maquina">
                            y = <span id="maquina-calc"><span>2/3</span> · <span style="color:var(--primary)" id="maq-x">6</span></span>
                        </div>
                        <div class="caja-control" style="border-left-color: var(--machine)">
                            <label>Tiempo Transcurrido (x): <span id="txt-x" style="color: var(--primary); font-size: 16px;">6</span></label>
                            <input type="range" id="slider-x" min="0" max="15" step="1" value="6">
                        </div>
                        <button id="btn-anim-corr" class="btn-accion" style="background: var(--machine)">Trazar Correspondencia ▶</button>
                        <button id="btn-limpiar-corr" class="btn-accion btn-limpiar">Limpiar Gráfico</button>
                    </div>
                </div>

                <div class="panel-visor">
                    <svg id="lienzo" viewBox="0 0 500 500" preserveAspectRatio="xMidYMid meet">
                        <defs>
                            <marker id="head-cov" orient="auto" markerWidth="4" markerHeight="4" refX="3" refY="2">
                                <path d="M0,0 L4,2 L0,4 Z" fill="var(--operator)" />
                            </marker>
                            <marker id="head-cor" orient="auto" markerWidth="4" markerHeight="4" refX="3" refY="2">
                                <path d="M0,0 L4,2 L0,4 Z" fill="var(--machine)" />
                            </marker>
                        </defs>

                        <g id="capa-grilla"></g>
                        
                        <line id="eje-x" class="eje" /> 
                        <line id="eje-y" class="eje" />  

                        <text id="lbl-o" text-anchor="end" class="eje-num">0</text>
                        <text id="lbl-ejex" text-anchor="end" class="eje-label">Bidón B (x) →</text>
                        <text id="lbl-ejey" text-anchor="start" class="eje-label">Bidón A (y) ↑</text>

                        <line id="recta-principal" class="recta-func" />
                        
                        <g id="capa-base"></g>
                        <g id="capa-animacion"></g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .recurso-wrapper {
        --primary: #D33C31;       
        --operator: #8B2E28;      
        --machine: #E87461;       
        --bg: #F4F4F2;            
        --text: #4A4A49;          
        --border: #D8D8D5;        
        
        font-family: 'Inter', system-ui, sans-serif;
        background-color: var(--bg);
        color: var(--text);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 20px;
        width: 100%;
        min-height: 100vh;
        box-sizing: border-box;
    }

    .card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(74, 74, 73, 0.08);
        border: 1px solid var(--border);
        width: 100%;
        max-width: 950px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .header-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 25px;
        border-bottom: 1px solid var(--border);
    }

    .header-bar h2 { margin: 0; font-size: 20px; color: var(--primary); transition: color 0.3s; }
    .header-bar p { margin: 4px 0 0 0; font-size: 14px; color: var(--text); opacity: 0.8; }

    .btn-toggle {
        background: var(--text); color: var(--bg); border: none; padding: 10px 20px;
        border-radius: 8px; font-weight: 600; cursor: pointer; transition: opacity 0.2s;
    }
    .btn-toggle:hover { opacity: 0.85; }

    .main-content { display: flex; height: 550px; }

    .panel-izquierdo {
        width: 340px; background: rgba(244, 244, 242, 0.5); border-right: 1px solid var(--border);
        padding: 25px; display: flex; flex-direction: column; gap: 20px;
        box-sizing: border-box;
    }

    .modo-container { display: none; flex-direction: column; gap: 20px; height: 100%; }
    .modo-container.active { display: flex; }

    .caja-control {
        background: white; padding: 15px; border-radius: 8px;
        border: 1px solid var(--border); display: flex; flex-direction: column; gap: 12px;
        border-left-width: 4px;
        border-left-style: solid;
    }

    .caja-control label { font-weight: 700; font-size: 13px; color: var(--text); text-transform: uppercase; }
    
    input[type="range"] { 
        width: 100%; cursor: pointer; height: 6px; background: var(--border); border-radius: 3px; outline: none; -webkit-appearance: none;
    }
    input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%;
        background: var(--primary); cursor: pointer; box-shadow: 0 2px 4px rgba(74,74,73,0.2);
    }

    .btn-accion {
        padding: 12px; border: none; border-radius: 8px; font-weight: 600; font-size: 14px;
        cursor: pointer; transition: all 0.2s; color: white; width: 100%;
    }
    .btn-accion:hover:not(:disabled) { filter: brightness(1.1); transform: translateY(-2px); }
    .btn-accion:disabled { background: var(--border) !important; cursor: not-allowed; transform: none; color: white; }

    .btn-limpiar { background: var(--text); margin-top: auto; }

    .maquina-coord {
        background: white; border: 2px solid var(--border); border-radius: 10px;
        padding: 15px 10px; text-align: center; font-family: 'Courier New', monospace;
        font-size: 20px; font-weight: 700; color: var(--text);
        box-shadow: inset 0 2px 10px rgba(74,74,73,0.03); min-height: 60px;
        display: flex; justify-content: center; align-items: center;
    }

    :global(.resultado-pop) { animation: pop-in 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
    @keyframes pop-in { 0% { transform: scale(0.8); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }

    .info-box { padding: 12px; border-radius: 8px; font-size: 13.5px; line-height: 1.5; border-left-width: 4px; border-left-style: solid; background: white; border-top: 1px solid var(--border); border-right: 1px solid var(--border); border-bottom: 1px solid var(--border);}

    .panel-visor {
        flex-grow: 1; background: white; padding: 20px; display: flex; justify-content: center; align-items: center;
    }
    svg { width: 100%; max-width: 500px; height: 100%; overflow: visible; }
    
    .eje { stroke: var(--text); stroke-width: 2.5; stroke-linecap: square; }
    .eje-num { font-size: 12px; fill: var(--text); font-weight: 500; }
    .eje-label { font-size: 13px; font-weight: 700; fill: var(--text); }
    .recta-func { stroke: var(--text); stroke-width: 2; stroke-dasharray: 4; opacity: 0.4; }

    /* Clases inyectadas vía JS que necesitan :global() */
    :global(.grilla-menor) { stroke: var(--bg); stroke-width: 1; }
    :global(.grilla-mayor) { stroke: var(--border); stroke-width: 1.5; }
    
    :global(.lbl-mat) { 
        font-size: 14px; 
        font-weight: 600; 
        paint-order: stroke fill; 
        stroke: var(--bg); 
        stroke-width: 3px; 
    }
    
    :global(.tri-base) { fill: var(--primary); opacity: 0.08; stroke: var(--primary); stroke-width: 1.5; stroke-dasharray: 3; }
    :global(.punto) { fill: var(--text); stroke: white; stroke-width: 2; }

    @media (max-width: 768px) {
        .main-content { flex-direction: column; height: auto; }
        .panel-izquierdo { width: 100%; border-right: none; border-bottom: 1px solid var(--border); }
    }
</style>

<script>
    const setupRecurso = () => {
        const xMax = 16, yMax = 12;
        const mX = 40, mY = 30, cW = 420, cH = 400;
        const baseLine = mY + cH;

        const mapX = (x: number) => mX + (x / xMax) * cW;
        const mapY = (y: number) => baseLine - (y / yMax) * cH;

        const btnToggle = document.getElementById('btn-toggle');
        const titulo = document.getElementById('titulo-modo');
        const desc = document.getElementById('desc-modo');
        const panCov = document.getElementById('modo-covariacion');
        const panCorr = document.getElementById('modo-correspondencia');
        const capaAnim = document.getElementById('capa-animacion');
        const capaBase = document.getElementById('capa-base');
        
        const sliderFact = document.getElementById('slider-factor') as HTMLInputElement;
        const btnAnimCov = document.getElementById('btn-anim-cov') as HTMLButtonElement;
        const sliderX = document.getElementById('slider-x') as HTMLInputElement;
        const btnAnimCorr = document.getElementById('btn-anim-corr') as HTMLButtonElement;

        let modoActual = 'covariacion'; 
        let animId: number | null = null;
        let resolucionActual: ((value: any) => void) | null = null; 

        if (!btnToggle || !capaAnim || !capaBase) return;

        function configurarPlano() {
            document.getElementById('eje-x')?.setAttribute('x1', mX.toString());
            document.getElementById('eje-x')?.setAttribute('y1', baseLine.toString());
            document.getElementById('eje-x')?.setAttribute('x2', (mX + cW + 20).toString());
            document.getElementById('eje-x')?.setAttribute('y2', baseLine.toString());

            document.getElementById('eje-y')?.setAttribute('x1', mX.toString());
            document.getElementById('eje-y')?.setAttribute('y1', baseLine.toString());
            document.getElementById('eje-y')?.setAttribute('x2', mX.toString());
            document.getElementById('eje-y')?.setAttribute('y2', (mY - 10).toString());

            document.getElementById('lbl-o')?.setAttribute('x', (mX - 8).toString());
            document.getElementById('lbl-o')?.setAttribute('y', (baseLine + 15).toString());
            document.getElementById('lbl-ejex')?.setAttribute('x', (mX + cW + 20).toString());
            document.getElementById('lbl-ejex')?.setAttribute('y', (baseLine + 35).toString());
            document.getElementById('lbl-ejey')?.setAttribute('x', mX.toString());
            document.getElementById('lbl-ejey')?.setAttribute('y', (mY - 20).toString());

            const grilla = document.getElementById('capa-grilla');
            if (grilla) {
                grilla.innerHTML = '';
                for(let i=1; i<=xMax; i++) {
                    let px = mapX(i);
                    grilla.innerHTML += `<line x1="${px}" y1="${baseLine}" x2="${px}" y2="${mY}" class="${i%3===0 ? 'grilla-mayor' : 'grilla-menor'}" />`;
                    if(i%3===0) grilla.innerHTML += `<text x="${px}" y="${baseLine+16}" text-anchor="middle" class="eje-num">${i}</text>`;
                }
                for(let j=1; j<=yMax; j++) {
                    let py = mapY(j);
                    grilla.innerHTML += `<line x1="${mX}" y1="${py}" x2="${mX+cW}" y2="${py}" class="${j%2===0 ? 'grilla-mayor' : 'grilla-menor'}" />`;
                    if(j%2===0) grilla.innerHTML += `<text x="${mX-8}" y="${py+4}" text-anchor="end" class="eje-num">${j}</text>`;
                }
            }

            document.getElementById('recta-principal')?.setAttribute('x1', mapX(0).toString());
            document.getElementById('recta-principal')?.setAttribute('y1', mapY(0).toString());
            document.getElementById('recta-principal')?.setAttribute('x2', mapX(15).toString());
            document.getElementById('recta-principal')?.setAttribute('y2', mapY(10).toString());
        }

        function dibujarTrianguloBase() {
            const bx = mapX(3), by = mapY(2), oy = mapY(0);
            if(capaBase) {
                capaBase.innerHTML = `
                    <path class="tri-base" d="M ${mX} ${oy} L ${bx} ${oy} L ${bx} ${by} Z" />
                    <text x="${(mX+bx)/2}" y="${oy - 6}" text-anchor="middle" class="lbl-mat" style="fill:var(--text)">Δx=3</text>
                    <text x="${bx - 6}" y="${(oy+by)/2 + 4}" text-anchor="end" class="lbl-mat" style="fill:var(--text)">Δy=2</text>
                `;
            }
        }

        function limpiarVisor() {
            if(animId) cancelAnimationFrame(animId);
            if(resolucionActual) resolucionActual({ interrumpido: true });
            if(capaAnim) capaAnim.innerHTML = '';
            document.querySelectorAll('.btn-accion').forEach(b => (b as HTMLButtonElement).disabled = false);
            document.querySelectorAll('input[type="range"]').forEach(i => (i as HTMLInputElement).disabled = false);
        }

        function dibujarVector(x1: number, y1: number, x2: number, y2: number, color: string, marker: string, duracion: number): Promise<any> {
            return new Promise(resolve => {
                resolucionActual = resolve;
                const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
                line.setAttribute('x1', x1.toString()); line.setAttribute('y1', y1.toString());
                line.setAttribute('x2', x1.toString()); line.setAttribute('y2', y1.toString());
                line.setAttribute('stroke', color);
                line.setAttribute('stroke-width', '3');
                line.setAttribute('stroke-linecap', 'round');
                line.setAttribute('marker-end', `url(#${marker})`);
                capaAnim?.appendChild(line);

                let start: number | null = null;
                function step(ts: number) {
                    if(!start) start = ts;
                    let p = Math.min((ts - start) / duracion, 1);
                    let ease = 1 - Math.pow(1 - p, 3);
                    
                    line.setAttribute('x2', (x1 + (x2 - x1) * ease).toString());
                    line.setAttribute('y2', (y1 + (y2 - y1) * ease).toString());
                    
                    if(p < 1) {
                        animId = requestAnimationFrame(step);
                    } else {
                        resolucionActual = null;
                        resolve({ interrumpido: false });
                    }
                }
                animId = requestAnimationFrame(step);
            });
        }

        function agregarPunto(x: number, y: number, color: string) {
            const pt = document.createElementNS("http://www.w3.org/2000/svg", "circle");
            pt.setAttribute('cx', x.toString()); pt.setAttribute('cy', y.toString());
            pt.setAttribute('r', '5');
            pt.setAttribute('fill', color);
            pt.setAttribute('stroke', 'var(--bg)');
            pt.setAttribute('stroke-width', '2');
            capaAnim?.appendChild(pt);
        }

        function agregarTexto(x: number, y: number, texto: string, color: string, anchor="middle") {
            const txt = document.createElementNS("http://www.w3.org/2000/svg", "text");
            txt.setAttribute('x', x.toString()); txt.setAttribute('y', y.toString());
            txt.setAttribute('text-anchor', anchor);
            txt.setAttribute('class', 'lbl-mat');
            txt.style.fill = color;
            txt.textContent = texto;
            capaAnim?.appendChild(txt);
        }

        // --- ASIGNACIÓN DE EVENTOS ---
        document.getElementById('btn-limpiar-cov')?.addEventListener('click', limpiarVisor);
        document.getElementById('btn-limpiar-corr')?.addEventListener('click', limpiarVisor);

        if (sliderFact) {
            sliderFact.addEventListener('input', (e) => {
                const target = e.target as HTMLInputElement;
                const txtFactor = document.getElementById('txt-factor');
                if (txtFactor) txtFactor.textContent = `× ${target.value}`;
            });
        }

        if (btnAnimCov) {
            btnAnimCov.addEventListener('click', async () => {
                limpiarVisor();
                btnAnimCov.disabled = true;
                sliderFact.disabled = true;

                const n = parseInt(sliderFact.value);
                const dx = 3, dy = 2; 
                const duracionFlecha = 300; 
                const colorOp = 'var(--operator)';

                for(let i = 0; i < n; i++) {
                    let startX = mapX(i * dx);
                    let endX = mapX((i + 1) * dx);
                    let posY = mapY(0);
                    
                    let res = await dibujarVector(startX, posY, endX, posY, colorOp, 'head-cov', duracionFlecha);
                    if (res.interrumpido) return;
                }

                agregarTexto(mapX((n*dx)/2), mapY(0) - 12, `${n} × Δx`, colorOp);

                for(let i = 0; i < n; i++) {
                    let posX = mapX(n * dx);
                    let startY = mapY(i * dy);
                    let endY = mapY((i + 1) * dy);
                    
                    let res = await dibujarVector(posX, startY, posX, endY, colorOp, 'head-cov', duracionFlecha);
                    if (res.interrumpido) return;
                }

                agregarTexto(mapX(n*dx) + 10, mapY((n*dy)/2) + 4, `${n} × Δy`, colorOp, 'start');
                agregarPunto(mapX(n*dx), mapY(n*dy), colorOp);

                btnAnimCov.disabled = false;
                sliderFact.disabled = false;
            });
        }

        if (sliderX) {
            sliderX.addEventListener('input', (e) => {
                const val = (e.target as HTMLInputElement).value;
                const txtX = document.getElementById('txt-x');
                const maqX = document.getElementById('maq-x');
                const maquinaCalc = document.getElementById('maquina-calc');
                
                if (txtX) txtX.textContent = val;
                if (maqX) maqX.textContent = val;
                if (maquinaCalc) maquinaCalc.innerHTML = `<span>2/3</span> · <span style="color:var(--primary)">${val}</span>`;
            });
        }

        if (btnAnimCorr) {
            btnAnimCorr.addEventListener('click', async () => {
                limpiarVisor();
                btnAnimCorr.disabled = true;
                sliderX.disabled = true;

                const x = parseFloat(sliderX.value);
                const y = (2/3) * x;
                const colorMac = 'var(--machine)';
                const maq = document.getElementById('maquina-calc');
                
                let res1 = await dibujarVector(mapX(0), mapY(0), mapX(x), mapY(0), colorMac, 'head-cor', 600);
                if(res1.interrumpido) return;
                
                agregarTexto(mapX(x/2), mapY(0) - 12, `x = ${x}`, colorMac);

                await new Promise(r => setTimeout(r, 200));
                
                if (maq) {
                    maq.innerHTML = `<span style="color:var(--machine)">${y.toFixed(1)}</span>`;
                    maq.parentElement?.classList.add('resultado-pop');
                }

                let res2 = await dibujarVector(mapX(x), mapY(0), mapX(x), mapY(y), colorMac, 'head-cor', 600);
                if(res2.interrumpido) return;

                agregarTexto(mapX(x) + 10, mapY(y/2) + 4, `y = ${y.toFixed(1)}`, colorMac, 'start');
                agregarPunto(mapX(x), mapY(y), colorMac);

                btnAnimCorr.disabled = false;
                sliderX.disabled = false;
                setTimeout(() => maq?.parentElement?.classList.remove('resultado-pop'), 500);
            });
        }

        if (btnToggle) {
            btnToggle.addEventListener('click', () => {
                limpiarVisor();
                if(modoActual === 'covariacion') {
                    modoActual = 'correspondencia';
                    if (titulo) { titulo.textContent = 'Enfoque de Correspondencia'; titulo.style.color = 'var(--machine)'; }
                    if (desc) desc.textContent = 'Correspondencia gráfica desde el dominio (X) hacia el recorrido (Y).';
                    btnToggle.innerHTML = 'Ver Covariación ⇄';
                    panCov?.classList.remove('active');
                    panCorr?.classList.add('active');
                    if (capaBase) capaBase.innerHTML = ''; 
                } else {
                    modoActual = 'covariacion';
                    if (titulo) { titulo.textContent = 'Enfoque Covariacional'; titulo.style.color = 'var(--primary)'; }
                    if (desc) desc.textContent = 'Escalamiento iterativo de las cantidades.';
                    btnToggle.innerHTML = 'Ver Correspondencia ⇄';
                    panCorr?.classList.remove('active');
                    panCov?.classList.add('active');
                    dibujarTrianguloBase();
                }
            });
        }

        configurarPlano();
        dibujarTrianguloBase();

        // Integración edX
        (window as any).getGrade = () => JSON.stringify({ action: "explore" });
        (window as any).getState = () => JSON.stringify({ action: "explore" });
        (window as any).setState = () => {};
    };

    document.addEventListener('DOMContentLoaded', setupRecurso);
    document.addEventListener('astro:page-load', setupRecurso);
</script>
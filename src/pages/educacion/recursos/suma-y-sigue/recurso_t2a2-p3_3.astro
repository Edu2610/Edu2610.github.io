---
import Layout from '../../../../layouts/Layout.astro';
// Ajusta la ruta al Layout según tu estructura de carpetas
---

<Layout titulo="Variación Escalar Múltiple">
    <div class="recurso-wrapper">
        <div class="card">
            <div class="header-text">
                <h3>Escalado Proporcional</h3>
                <p>Encuentra el factor de multiplicación o división desde la columna base.</p>
            </div>

            <div class="interactive-container">
                
                <svg class="svg-layer svg-top" viewBox="0 0 700 160">
                    <defs>
                        <marker id="arrow-blue" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="4" markerHeight="4" orient="auto">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#2563eb" />
                        </marker>
                    </defs>
                    <path d="M 315 155 Q 260 70 205 155" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                    <path d="M 315 155 Q 370 70 425 155" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                    <path d="M 315 155 Q 450 -10 535 155" fill="none" stroke="#2563eb" stroke-width="3.5" marker-end="url(#arrow-blue)" />
                    <path d="M 315 155 Q 520 -90 645 155" fill="none" stroke="#2563eb" stroke-width="5" marker-end="url(#arrow-blue)" />
                </svg>

                <input type="text" id="top1" class="jump-input input-blue" style="left: 260px; top: -48px;" autocomplete="off">
                <input type="text" id="top2" class="jump-input input-blue" style="left: 370px; top: -48px;" autocomplete="off">
                <input type="text" id="top3" class="jump-input input-blue" style="left: 438px; top: -88px;" autocomplete="off">
                <input type="text" id="top4" class="jump-input input-blue" style="left: 500px; top: -127px;" autocomplete="off">

                <table>
                    <tr>
                        <td class="col-header">Tazas de harina</td>
                        <td>1,5</td>
                        <td>3</td>
                        <td>4,5</td>
                        <td>12</td>
                        <td>60</td>
                    </tr>
                    <tr>
                        <td class="col-header">Tazas de Azúcar</td>
                        <td class="val-red">1</td>
                        <td>2</td>
                        <td class="val-red">3</td>
                        <td class="val-red">8</td>
                        <td class="val-red">40</td>
                    </tr>
                </table>

                <svg class="svg-layer svg-bottom" viewBox="0 0 700 160">
                    <defs>
                        <marker id="arrow-red" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="4" markerHeight="4" orient="auto">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#d32f2f" />
                        </marker>
                    </defs>
                    <path d="M 315 5 Q 260 90 205 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                    <path d="M 315 5 Q 370 90 425 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                    <path d="M 315 5 Q 450 170 535 5" fill="none" stroke="#d32f2f" stroke-width="3.5" marker-end="url(#arrow-red)" />
                    <path d="M 315 5 Q 520 250 645 5" fill="none" stroke="#d32f2f" stroke-width="5" marker-end="url(#arrow-red)" />
                </svg>

                <input type="text" id="bot1" class="jump-input input-red" style="left: 260px; bottom: -78px;" autocomplete="off">
                <input type="text" id="bot2" class="jump-input input-red" style="left: 370px; bottom: -78px;" autocomplete="off">
                <input type="text" id="bot3" class="jump-input input-red" style="left: 448px; bottom: -110px;" autocomplete="off">
                <input type="text" id="bot4" class="jump-input input-red" style="left: 510px; bottom: -156px;" autocomplete="off">

            </div>

            <button id="btn-verify" class="btn-verify">Verificar Relaciones</button>
            <div id="feedback" class="feedback-text"></div>
        </div>
    </div>
</Layout>

<style>
    .recurso-wrapper {
        font-family: 'Inter', sans-serif;
        display: flex;
        justify-content: center;
        padding: 40px 20px;
        width: 100%;
    }

    .card {
        background: white;
        padding: 40px 20px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        max-width: 850px; 
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .header-text { text-align: center; margin-bottom: 20px; }
    .header-text h3 { color: #0f172a; margin: 0 0 5px 0; font-size: 1.25rem; }
    .header-text p { color: #64748b; font-size: 0.9rem; margin: 0; }

    .interactive-container {
        width: 700px; 
        position: relative;
        margin-top: 140px; 
        margin-bottom: 180px; /* Aumentado para alojar correctamente el input en -156px */
    }

    table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
        position: relative;
        z-index: 1;
    }

    td {
        border: 1px solid #475569;
        height: 70px;
        text-align: center;
        vertical-align: middle;
        font-size: 1.25rem;
        font-weight: 700;
        color: #1e293b;
    }

    .val-red { color: #ef4444; }

    .col-header {
        width: 150px;
        background-color: #f1f5f9;
        font-weight: 700;
        text-align: center;
        padding: 0 10px;
        color: #0f172a;
        font-size: 1.1rem;
    }

    .jump-input {
        position: absolute;
        width: 46px; 
        height: 26px;
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        font-weight: 800;
        text-align: center;
        border: 2px solid #cbd5e1;
        border-radius: 4px;
        background: #ffffff;
        transition: all 0.2s;
        outline: none;
        z-index: 10;
        transform: translate(-50%, -50%); 
    }

    .jump-input:focus { box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15); }
    .input-blue { color: #2563eb; }
    .input-blue:focus { border-color: #2563eb; }
    .input-red { color: #d32f2f; }
    .input-red:focus { border-color: #d32f2f; }

    .correct { background-color: #ecfdf5 !important; border-color: #10b981 !important; color: #047857 !important; }
    .incorrect { background-color: #fef2f2 !important; border-color: #ef4444 !important; color: #b91c1c !important; }

    .btn-verify {
        padding: 12px 30px;
        border: none;
        border-radius: 8px;
        background: #0f172a;
        color: white;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
    }

    .btn-verify:hover:not(:disabled) { background: #334155; transform: translateY(-2px); }
    .btn-verify:disabled { background: #cbd5e1; cursor: not-allowed; color: #f8fafc; }

    .feedback-text {
        margin-top: 15px;
        font-size: 0.9rem;
        font-weight: 600;
        min-height: 20px;
        text-align: center;
    }

    .svg-layer {
        position: absolute;
        left: 0;
        width: 100%;
        pointer-events: none; 
        overflow: visible;
    }
    
    .svg-top { top: -160px; height: 160px; }
    .svg-bottom { bottom: -160px; height: 160px; }
</style>

<script>
    const setupEscalado = () => {
        const correctAnswers: Record<string, string> = {
            top1: "÷ 2", top2: "x 1,5", top3: "x 4", top4: "x 20",
            bot1: "÷ 2", bot2: "x 1,5", bot3: "x 4", bot4: "x 20"
        };

        let estadoEjercicio: Record<string, string> = {};
        const inputIds = Object.keys(correctAnswers);
        
        inputIds.forEach(id => {
            estadoEjercicio[id] = "";
        });

        const btnVerify = document.getElementById('btn-verify') as HTMLButtonElement | null;
        const feedback = document.getElementById('feedback') as HTMLElement | null;

        if (!btnVerify || !feedback) return;

        function formatAnswer(userVal: string) {
            let clean = userVal.toLowerCase().replace(/\s+/g, '').replace(',', '.');
            
            if (['÷2', '/2', ':2', 'x0.5', '*0.5'].includes(clean)) return '÷ 2';
            if (['x1.5', '*1.5'].includes(clean)) return 'x 1,5';
            if (['x4', '*4'].includes(clean)) return 'x 4';
            if (['x20', '*20'].includes(clean)) return 'x 20';
            
            return userVal;
        }

        inputIds.forEach(id => {
            const input = document.getElementById(id) as HTMLInputElement | null;
            if (!input) return;

            // Limpieza de eventos
            const newClone = input.cloneNode(true) as HTMLInputElement;
            input.parentNode?.replaceChild(newClone, input);

            newClone.addEventListener('input', (e) => {
                estadoEjercicio[id] = (e.target as HTMLInputElement).value;
            });
        });

        const newBtnVerify = btnVerify.cloneNode(true) as HTMLButtonElement;
        btnVerify.parentNode?.replaceChild(newBtnVerify, btnVerify);

        newBtnVerify.addEventListener('click', () => {
            let correctCount = 0;

            inputIds.forEach(id => {
                const input = document.getElementById(id) as HTMLInputElement | null;
                if (!input) return;

                const userVal = formatAnswer(estadoEjercicio[id]);
                const correctVal = correctAnswers[id];

                input.disabled = true;

                if (userVal === correctVal) {
                    input.classList.add('correct');
                    input.value = correctVal; 
                    correctCount++;
                } else {
                    input.classList.add('incorrect');
                    input.value = correctVal; 
                }
            });

            if (correctCount === inputIds.length) {
                feedback.style.color = "#047857";
                feedback.textContent = "¡Impecable! Has identificado correctamente todos los factores de proporcionalidad.";
            } else {
                feedback.style.color = "#b91c1c";
                feedback.textContent = `Hay errores. Revisa las casillas en rojo para identificar la operación correcta.`;
            }

            newBtnVerify.disabled = true;
        });

        // Exponer la API a 'window' para edX
        (window as any).getGrade = () => JSON.stringify(estadoEjercicio);
        (window as any).getState = () => JSON.stringify(estadoEjercicio);
        (window as any).setState = (stateStr: string) => {
            if (!stateStr) return;
            try {
                estadoEjercicio = JSON.parse(stateStr);
                inputIds.forEach(id => {
                    if (estadoEjercicio[id] !== "") {
                        const input = document.getElementById(id) as HTMLInputElement | null;
                        if (input) input.value = estadoEjercicio[id];
                    }
                });
            } catch(e) {
                console.error("Error parseando estado", e);
            }
        };
    };

    document.addEventListener('DOMContentLoaded', setupEscalado);
    document.addEventListener('astro:page-load', setupEscalado);
</script>
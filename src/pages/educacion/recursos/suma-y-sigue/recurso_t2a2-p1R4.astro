---
import Layout from '../../../../layouts/Layout.astro';
---

<Layout titulo="Covariación No Proporcional">
    <div class="recurso-wrapper">
        <div class="card">
            <div class="header-text">
                
            </div>

            <div class="interactive-container">
                
                <svg class="svg-layer svg-top" viewBox="0 0 960 40">
                    <defs>
                        <marker id="arrow-blue" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#2563eb" />
                        </marker>
                    </defs>
                    <path d="M 255 35 Q 310 -10 365 35" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                    <path d="M 385 35 Q 440 -10 495 35" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                    <path d="M 515 35 Q 570 -10 625 35" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                    <path d="M 645 35 Q 700 -10 755 35" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                    <path d="M 775 35 Q 830 -10 885 35" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                </svg>

                <input type="text" id="top1" class="jump-input input-blue" style="left: 310px; top: -55px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="top2" class="jump-input input-blue" style="left: 440px; top: -55px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="top3" class="jump-input input-blue" style="left: 570px; top: -55px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="top4" class="jump-input input-blue" style="left: 700px; top: -55px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="top5" class="jump-input input-blue" style="left: 830px; top: -55px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">

                <table>
                    <tr>
                        <td class="col-header">x: Medida del lado (cm)</td>
                        <td>1</td>
                        <td>2</td>
                        <td>3</td>
                        <td>4</td>
                        <td>5</td>
                        <td>6</td>
                    </tr>
                    <tr>
                        <td class="col-header">y: Área del cuadrado (cm²)</td>
                        <td>1</td>
                        <td>4</td>
                        <td>9</td>
                        <td>16</td>
                        <td>25</td>
                        <td>36</td>
                    </tr>
                </table>

                <svg class="svg-layer svg-bottom" viewBox="0 0 960 40">
                    <defs>
                        <marker id="arrow-red" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#d32f2f" />
                        </marker>
                    </defs>
                    <path d="M 255 5 Q 310 50 365 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                    <path d="M 385 5 Q 440 50 495 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                    <path d="M 515 5 Q 570 50 625 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                    <path d="M 645 5 Q 700 50 755 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                    <path d="M 775 5 Q 830 50 885 5" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                </svg>

                <input type="text" id="bot1" class="jump-input input-red" style="left: 310px; bottom: -85px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="bot2" class="jump-input input-red" style="left: 440px; bottom: -85px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="bot3" class="jump-input input-red" style="left: 570px; bottom: -85px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="bot4" class="jump-input input-red" style="left: 700px; bottom: -85px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">
                <input type="text" id="bot5" class="jump-input input-red" style="left: 830px; bottom: -85px;" autocomplete="off" inputmode="text" pattern="[0-9+\-]*">

            </div>

            <button id="btn-verify" class="btn-verify">Verificar Respuesta</button>
            <div id="feedback" class="feedback-text"></div>
        </div>
    </div>
</Layout>

<style>
    .recurso-wrapper {
        font-family: 'Inter', system-ui, sans-serif;
        background: #f8fafc;
        display: flex;
        justify-content: center;
        padding: 40px 20px;
        width: 100%;
    }

    .card {
        background: white;
        padding: 40px 20px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        max-width: 1000px;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        overflow-x: auto;
    }

    .header-text { text-align: center; margin-bottom: 20px; }
    .header-text p.title { color: #0f172a; margin: 0 0 5px 0; font-size: 1.25rem; font-weight: 700; }
    .header-text p.desc { color: #64748b; font-size: 0.95rem; margin: 0; }

    .interactive-container {
        width: 960px;
        position: relative;
        margin-top: 70px; 
        margin-bottom: 70px; 
    }

    table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
        position: relative;
        z-index: 1;
    }

    td {
        border: 1px solid #475569;
        height: 60px;
        text-align: center;
        vertical-align: middle;
        font-size: 1.2rem;
        font-weight: 600;
        color: #1e293b;
    }

    .col-header {
        width: 180px;
        background-color: #f1f5f9;
        font-weight: 700;
        text-align: right;
        padding-right: 15px;
    }

    .jump-input {
        position: absolute;
        width: 44px;
        height: 28px;
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        text-align: center;
        border: 2px solid #cbd5e1;
        border-radius: 6px;
        background: #ffffff;
        transition: all 0.2s;
        outline: none;
        z-index: 10;
        transform: translate(-50%, -50%); 
    }

    .jump-input:focus { box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15); }
    .input-blue { color: #2563eb; }
    .input-blue:focus { border-color: #2563eb; }
    .input-red { color: #d32f2f; }
    .input-red:focus { border-color: #d32f2f; }

    .correct { background-color: #ecfdf5 !important; border-color: #10b981 !important; color: #047857 !important; }
    .incorrect { background-color: #fef2f2 !important; border-color: #ef4444 !important; color: #b91c1c !important; }

    .btn-verify {
        padding: 12px 30px;
        margin-top: 10px;
        border: none;
        border-radius: 8px;
        background: #0f172a;
        color: white;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
    }

    .btn-verify:hover:not(:disabled) { background: #334155; transform: translateY(-2px); }
    .btn-verify:disabled { background: #cbd5e1; cursor: not-allowed; color: #f8fafc; }

    .feedback-text {
        margin-top: 15px;
        font-size: 0.95rem;
        font-weight: 400;
        line-height: 1.5;
        min-height: 20px;
        text-align: center;
        max-width: 600px;
    }

    .svg-layer {
        position: absolute;
        left: 0;
        width: 100%;
        pointer-events: none; 
    }
    .svg-top { top: -40px; height: 40px; }
    .svg-bottom { bottom: -40px; height: 40px; }
</style>

<script>
    const setupVariacionNoProporcional = () => {
        const correctAnswers: Record<string, string> = {
            top1: "+1", top2: "+1", top3: "+1", top4: "+1", top5: "+1",
            bot1: "+3", bot2: "+5", bot3: "+7", bot4: "+9", bot5: "+11"
        };

        let estadoSaltos: Record<string, string> = {
            top1: "", top2: "", top3: "", top4: "", top5: "",
            bot1: "", bot2: "", bot3: "", bot4: "", bot5: ""
        };

        const btnVerify = document.getElementById('btn-verify') as HTMLButtonElement | null;
        const feedback = document.getElementById('feedback') as HTMLElement | null;
        const inputIds = Object.keys(correctAnswers);

        if (!btnVerify || !feedback) return;

        function formatAnswer(val: string, expected: string) {
            let clean = val.trim();
            if (expected.startsWith("+") && clean === expected.substring(1)) return expected;
            return clean;
        }

        inputIds.forEach(id => {
            const input = document.getElementById(id) as HTMLInputElement | null;
            if (!input) return;

            const newClone = input.cloneNode(true) as HTMLInputElement;
            input.parentNode?.replaceChild(newClone, input);

            newClone.addEventListener('input', (e) => {
                estadoSaltos[id] = (e.target as HTMLInputElement).value;
            });
        });

        const newBtnVerify = btnVerify.cloneNode(true) as HTMLButtonElement;
        btnVerify.parentNode?.replaceChild(newBtnVerify, btnVerify);

        newBtnVerify.addEventListener('click', () => {
            let correctCount = 0;

            inputIds.forEach(id => {
                const input = document.getElementById(id) as HTMLInputElement | null;
                if (!input) return;

                const userVal = formatAnswer(estadoSaltos[id], correctAnswers[id]);
                const correctVal = correctAnswers[id];

                input.disabled = true;

                if (userVal === correctVal) {
                    input.classList.add('correct');
                    input.value = correctVal; 
                    correctCount++;
                } else {
                    input.classList.add('incorrect');
                    input.value = correctVal; 
                }
            });

            if (correctCount === inputIds.length) {
                feedback.style.color = "#047857";
                feedback.innerHTML = "¡Excelente!</strong>";
            } else {
                feedback.style.color = "#b91c1c";
                feedback.textContent = "Hay errores en el cálculo de las diferencias. ";
            }

            newBtnVerify.disabled = true;
        });

        // ==========================================
        // INTEGRACIÓN EDX (JSInput API)
        // ==========================================
        (window as any).getGrade = () => JSON.stringify(estadoSaltos);
        (window as any).getState = () => JSON.stringify(estadoSaltos);
        (window as any).setState = (stateStr: string) => {
            if (!stateStr) return;
            try {
                estadoSaltos = JSON.parse(stateStr);
                inputIds.forEach(id => {
                    if (estadoSaltos[id] !== "") {
                        const input = document.getElementById(id) as HTMLInputElement | null;
                        if (input) input.value = estadoSaltos[id];
                    }
                });
            } catch(e) {
                console.error("Error restaurando estado en edX", e);
            }
        };
    };

    document.addEventListener('DOMContentLoaded', setupVariacionNoProporcional);
    document.addEventListener('astro:page-load', setupVariacionNoProporcional);
</script>
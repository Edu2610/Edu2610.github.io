---
import Layout from '../../../../layouts/Layout.astro';
// Ajusta la ruta al Layout según corresponda
---

<Layout titulo="Explorador de la Relación">
    <script is:inline src="https://cdn.plot.ly/plotly-2.24.1.min.js"></script>

    <div class="recurso-wrapper">
        <div class="card">
            <h2>Explorador de la Relación y = 12 - x</h2>
            
            <div class="controls">
                <div class="input-group">
                    <label>Ingresar Punto Nuevo:</label>
                    <div class="input-row">
                        <input type="number" id="inputX" step="0.1" placeholder="x (Bidón B)">
                        <input type="number" id="inputY" step="0.1" placeholder="y (Bidón A)">
                    </div>
                    <button id="btn-plot" class="btn-plot">Graficar Punto</button>
                </div>
                <div class="input-group">
                    <label>Acciones de Modelo:</label>
                    <button id="btn-trace" class="btn-trace">Trazar / Ocultar Recta</button>
                    <button id="btn-reset" class="btn-reset">Reiniciar</button>
                </div>
            </div>

            <div id="feedback"></div>
            <div id="plot"></div>
        </div>
    </div>
</Layout>

<style>
    .recurso-wrapper {
        --primary: #D32F2F;
        --secondary: #FB8C00;
        --bg: transparent;
        --text: #1E293B;
        
        font-family: 'Inter', system-ui, sans-serif;
        display: flex;
        justify-content: center;
        padding: 40px 20px;
        width: 100%;
        color: var(--text);
    }

    .card {
        background: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        max-width: 800px;
        width: 100%;
    }

    h2 { color: var(--primary); margin-top: 0; text-align: center; }

    .controls {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
        padding: 20px;
        background: #f1f5f9;
        border-radius: 10px;
    }

    @media (max-width: 600px) {
        .controls { grid-template-columns: 1fr; }
    }

    .input-group { display: flex; flex-direction: column; gap: 10px; }
    .input-group label { font-weight: 600; font-size: 0.9rem; color: #475569; }
    
    .input-row { display: flex; gap: 8px; }
    
    input {
        width: 100%;
        padding: 10px;
        border: 2px solid #cbd5e1;
        border-radius: 6px;
        font-size: 1rem;
        outline: none;
        transition: border-color 0.2s;
    }

    input:focus { border-color: var(--primary); }

    button {
        padding: 12px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 700;
        transition: 0.2s;
        font-size: 0.95rem;
    }

    .btn-plot { background: var(--primary); color: white; }
    .btn-trace { background: var(--secondary); color: white; }
    .btn-reset { background: #64748b; color: white; }

    button:hover { opacity: 0.9; transform: translateY(-2px); }

    #feedback {
        margin-top: 10px;
        padding: 12px;
        border-radius: 6px;
        font-weight: 600;
        text-align: center;
        min-height: 24px;
        transition: all 0.3s;
    }

    .success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
    .error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }

    #plot { width: 100%; height: 500px; margin-top: 20px; }
</style>

<script>
    // Declaración para que TypeScript reconozca el CDN inyectado
    declare const Plotly: any;

    const setupGrafico = () => {
        const plotDiv = document.getElementById('plot');
        const btnPlot = document.getElementById('btn-plot') as HTMLButtonElement;
        const btnToggle = document.getElementById('btn-trace') as HTMLButtonElement;
        const btnReset = document.getElementById('btn-reset') as HTMLButtonElement;
        const inputX = document.getElementById('inputX') as HTMLInputElement;
        const inputY = document.getElementById('inputY') as HTMLInputElement;
        const fb = document.getElementById('feedback');

        if (!plotDiv || !btnPlot || !btnToggle || !btnReset || !inputX || !inputY || !fb) return;

        let showLine = false;
        
        const initialPoints = {
            x: [0, 1, 4, 4.5, 8, 12],
            y: [12, 11, 8, 7.5, 4, 0],
            mode: 'markers',
            name: 'Puntos de Tabla',
            marker: { size: 10, color: '#1E293B' }
        };

        let userPoints = {
            x: [] as number[], 
            y: [] as number[],
            mode: 'markers',
            name: 'Tus Puntos',
            marker: { size: 12, color: '#D32F2F', symbol: 'diamond' }
        };

        function draw() {
            const line = {
                x: [0, 12],
                y: [12, 0],
                mode: 'lines',
                name: 'Modelo Continuo',
                line: { color: '#FB8C00', width: 3 },
                visible: showLine
            };

            const layout = {
                xaxis: { title: 'Litros en Bidón B (x)', range: [-0.5, 13], dtick: 1 },
                yaxis: { title: 'Litros en Bidón A (y)', range: [-0.5, 13], dtick: 1 },
                margin: { t: 20 },
                hovermode: 'closest'
            };

            // Asegurarse de que Plotly esté cargado antes de llamar a newPlot
            if (typeof Plotly !== 'undefined') {
                Plotly.newPlot('plot', [initialPoints, userPoints, line], layout);
            }
        }

        // Clonar nodos para limpiar listeners (necesario por Astro View Transitions)
        const newBtnPlot = btnPlot.cloneNode(true) as HTMLButtonElement;
        btnPlot.parentNode?.replaceChild(newBtnPlot, btnPlot);
        
        const newBtnToggle = btnToggle.cloneNode(true) as HTMLButtonElement;
        btnToggle.parentNode?.replaceChild(newBtnToggle, btnToggle);
        
        const newBtnReset = btnReset.cloneNode(true) as HTMLButtonElement;
        btnReset.parentNode?.replaceChild(newBtnReset, btnReset);

        newBtnPlot.addEventListener('click', () => {
            const x = parseFloat(inputX.value);
            const y = parseFloat(inputY.value);

            if (isNaN(x) || isNaN(y)) {
                fb.innerHTML = "Ingresa valores válidos";
                fb.className = "error";
                return;
            }

            userPoints.x.push(x);
            userPoints.y.push(y);

            if (Math.abs((x + y) - 12) < 0.001) {
                fb.className = "success";
                fb.innerHTML = `✓ El punto (${x}, ${y}) PERTENECE al gráfico. Cumple x + y = 12.`;
            } else {
                fb.className = "error";
                fb.innerHTML = `✗ El punto (${x}, ${y}) NO pertenece al gráfico. La suma es ${x + y}, no 12.`;
            }

            draw();
        });

        newBtnToggle.addEventListener('click', () => {
            showLine = !showLine;
            draw();
        });

        newBtnReset.addEventListener('click', () => {
            userPoints.x = [];
            userPoints.y = [];
            showLine = false;
            fb.innerHTML = "";
            fb.className = "";
            inputX.value = "";
            inputY.value = "";
            draw();
        });

        // Retrasar el primer dibujo unos milisegundos para dar tiempo al CDN de Plotly a cargar
        setTimeout(() => {
            if (typeof Plotly !== 'undefined') {
                draw();
            } else {
                fb.innerHTML = "Cargando motor gráfico...";
                const checkPlotly = setInterval(() => {
                    if (typeof Plotly !== 'undefined') {
                        clearInterval(checkPlotly);
                        fb.innerHTML = "";
                        draw();
                    }
                }, 200);
            }
        }, 100);
    };

    document.addEventListener('DOMContentLoaded', setupGrafico);
    document.addEventListener('astro:page-load', setupGrafico);
</script>
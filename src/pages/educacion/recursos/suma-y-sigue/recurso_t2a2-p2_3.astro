---
import Layout from '../../../../layouts/Layout.astro';
// Asegúrate de que la ruta al Layout sea la correcta
---

<Layout titulo="Explorador Covariacional: Bidones">
    <script is:inline src="https://cdn.plot.ly/plotly-2.24.1.min.js"></script>

    <div class="recurso-wrapper">
        <div class="card">
            <div class="header-actions">
                <h3 id="mainTitle">Enfoque Covariacional</h3>
                <button id="btnClear" class="btn-clear">Limpiar Sombras</button>
            </div>
            
            <div id="panelCovariation">
                <div class="header-text">
                    <p>Define un punto inicial (x) y un incremento positivo (Δx) para observar la variación conjunta.</p>
                </div>
                <div class="controls">
                    <div class="slider-group">
                        <label>Punto Inicial (x): <span id="valX" class="label-val">2</span></label>
                        <input type="range" id="slideX" min="0" max="12" step="1" value="2">
                    </div>
                    <div class="slider-group">
                        <label>Incremento (Δx): <span id="valDx" class="label-val">4</span></label>
                        <input type="range" id="slideDx" min="0" max="12" step="1" value="4">
                    </div>
                </div>
                <div class="info-box info-covariation">
                    <strong>Análisis de Covariación:</strong>
                    Para un incremento de <span class="text-blue">Δx = <span id="dxText">4</span></span>, 
                    la variable dependiente cambia <span class="text-red">Δy = <span id="dyText">-4</span></span>.
                </div>
            </div>

            <div id="plot"></div>
        </div>
    </div>
</Layout>

<style>
    .recurso-wrapper {
        font-family: 'Inter', sans-serif;
        display: flex;
        justify-content: center;
        padding: 40px 20px;
        width: 100%;
        background-color: #f8fafc;
    }

    .card {
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        max-width: 800px;
        width: 100%;
    }

    .header-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e2e8f0;
        padding-bottom: 15px;
        margin-bottom: 20px;
    }

    #mainTitle { margin: 0; font-size: 1.5rem; color: #d32f2f; }

    .header-text { margin-bottom: 15px; text-align: left; }
    .header-text p { color: #64748b; font-size: 0.95rem; margin: 0; }

    .controls {
        display: flex;
        gap: 30px;
        background: #f1f5f9;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 15px;
        align-items: center;
        justify-content: space-around;
        min-height: 80px;
    }

    @media (max-width: 600px) {
        .controls { flex-direction: column; gap: 15px; }
        .header-actions { flex-direction: column; gap: 15px; align-items: flex-start; }
    }

    .slider-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex-grow: 1;
        width: 100%;
    }

    .slider-group label { color: #475569; font-size: 0.95rem; }
    .label-val { font-weight: 800; color: #1e293b; }
    
    input[type=range] { width: 100%; cursor: pointer; }

    button { cursor: pointer; padding: 10px 18px; border: none; border-radius: 6px; font-weight: bold; transition: background 0.2s; font-size: 0.95rem; }
    .btn-clear { background: #64748b; color: white; }
    .btn-clear:hover { background: #475569; }

    #plot { width: 100%; height: 550px; }

    .info-box {
        padding: 15px;
        font-size: 1rem;
        margin-top: 15px;
        border-radius: 4px;
        color: #1e293b;
    }
    
    .info-covariation { border-left: 4px solid #d32f2f; background: #fff1f2; }

    .text-blue { color: #2563eb; font-weight: 600; }
    .text-red { color: #d32f2f; font-weight: 600; }
</style>

<script>
    declare const Plotly: any;

    const setupCovariacion = () => {
        // Nodos DOM
        const slideX = document.getElementById('slideX') as HTMLInputElement | null;
        const slideDx = document.getElementById('slideDx') as HTMLInputElement | null;
        const valX = document.getElementById('valX') as HTMLElement | null;
        const valDx = document.getElementById('valDx') as HTMLElement | null;
        const dxText = document.getElementById('dxText') as HTMLElement | null;
        const dyText = document.getElementById('dyText') as HTMLElement | null;
        const btnClear = document.getElementById('btnClear') as HTMLButtonElement | null;
        const plotDiv = document.getElementById('plot') as HTMLElement | null;

        if (!slideX || !slideDx || !plotDiv) return;

        // Estado local para edX
        let estadoEjercicio = {
            posX: slideX.value,
            posDx: slideDx.value
        };

        let shadowTraces: any[] = [];

        const layoutBase = {
            xaxis: { title: 'Litros en Bidón B (x)', range: [0, 12.5], dtick: 1, gridcolor: '#e2e8f0', rangemode: 'nonnegative', constrain: 'domain' },
            yaxis: { 
                title: 'Litros en Bidón A (y)', 
                range: [0, 12.5], 
                dtick: 1, 
                gridcolor: '#e2e8f0',
                scaleanchor: "x", 
                scaleratio: 1,
                rangemode: 'nonnegative'
            },
            showlegend: false,
            margin: { t: 30, b: 40, l: 50, r: 20 },
            hovermode: false
        };

        const traceLineBase = {
            x: [0, 12], y: [12, 0],
            mode: 'lines', name: 'Recta',
            line: { color: '#94a3b8', width: 2, dash: 'dot' },
            hoverinfo: 'skip'
        };

        function renderPlot(saveShadow = false) {
            let x1 = parseFloat(slideX!.value);
            let dx = parseFloat(slideDx!.value);
            
            // Corrección de límites
            if (x1 + dx > 12) {
                dx = 12 - x1;
                slideDx!.value = dx.toString();
            }
            
            let x2 = x1 + dx;
            const y1 = 12 - x1;
            const y2 = 12 - x2;
            const dy = y2 - y1;

            valX!.innerText = x1.toString();
            valDx!.innerText = dx.toString();
            dxText!.innerText = dx.toString();
            dyText!.innerText = dy.toString();

            // Guardar estado edX
            estadoEjercicio.posX = x1.toString();
            estadoEjercicio.posDx = dx.toString();

            const currentTriangle = {
                x: [x1, x2, x2], y: [y1, y1, y2],
                mode: 'lines', fill: 'toself', fillcolor: 'rgba(211, 47, 47, 0.2)',
                line: { color: '#d32f2f', width: 3 },
                hoverinfo: 'skip'
            };

            if (saveShadow && dx > 0) {
                shadowTraces.push({
                    x: [x1, x2, x2], y: [y1, y1, y2],
                    mode: 'lines', fill: 'toself', fillcolor: 'rgba(100, 116, 139, 0.2)',
                    line: { color: '#64748b', width: 1.5 },
                    hoverinfo: 'skip'
                });
            }

            const points = {
                x: [x1, x2], y: [y1, y2],
                mode: 'markers+text', marker: { size: 10, color: '#1e293b' },
                text: [`A(${x1}, ${y1})`, `B(${x2}, ${y2})`],
                textposition: ['top right', 'bottom right'],
                hoverinfo: 'skip'
            };

            const layout = { ...layoutBase, annotations: [] as any[] };
            
            if (dx > 0) {
                layout.annotations.push(
                    { 
                        x: (x1 + x2) / 2, y: y1, 
                        text: `Δx = ${dx}`, 
                        showarrow: false, font: { color: '#2563eb', weight: 'bold' },
                        yshift: 10, yanchor: 'bottom'
                    },
                    { 
                        x: x2, y: (y1 + y2) / 2, 
                        text: `Δy = ${dy}`, 
                        showarrow: false, font: { color: '#d32f2f', weight: 'bold' },
                        xshift: 10, xanchor: 'left'
                    }
                );
            }

            if (typeof Plotly !== 'undefined') {
                Plotly.react('plot', [traceLineBase, ...shadowTraces, currentTriangle, points], layout);
            }
        }

        // Eventos
        slideX!.addEventListener('input', () => renderPlot(false));
        slideDx!.addEventListener('input', () => renderPlot(false));
        
        slideX!.addEventListener('change', () => renderPlot(true));
        slideDx!.addEventListener('change', () => renderPlot(true));

        btnClear!.addEventListener('click', () => {
            shadowTraces = [];
            renderPlot(false);
        });

        // Inicialización robusta para evitar errores si Plotly tarda en cargar
        const initPlot = () => {
            if (typeof Plotly !== 'undefined') {
                renderPlot(true);
            } else {
                plotDiv!.innerHTML = "<p style='text-align:center; color:#64748b; margin-top:100px;'>Cargando motor gráfico...</p>";
                const checkPlotly = setInterval(() => {
                    if (typeof Plotly !== 'undefined') {
                        clearInterval(checkPlotly);
                        plotDiv!.innerHTML = "";
                        renderPlot(true);
                    }
                }, 200);
            }
        };

        initPlot();

        // JSInput API de edX
        (window as any).getGrade = () => JSON.stringify(estadoEjercicio);
        (window as any).getState = () => JSON.stringify(estadoEjercicio);
        (window as any).setState = (stateStr: string) => {
            if (!stateStr) return;
            try {
                const state = JSON.parse(stateStr);
                estadoEjercicio = state;
                
                if (state.posX) slideX!.value = state.posX;
                if (state.posDx) slideDx!.value = state.posDx;
                
                if (typeof Plotly !== 'undefined') {
                    renderPlot(false);
                }
            } catch(e) {
                console.error("Error restaurando estado en edX", e);
            }
        };
    };

    document.addEventListener('DOMContentLoaded', setupCovariacion);
    document.addEventListener('astro:page-load', setupCovariacion);
</script>
---
import Layout from '../../../../layouts/Layout.astro';
// Asegúrate de que la ruta al Layout sea la correcta
---

<Layout titulo="Explorador de Relaciones: Bidones">
    <script is:inline src="https://cdn.plot.ly/plotly-2.24.1.min.js"></script>

    <div class="recurso-wrapper">
        <div class="card">
            <div class="header-actions">
                <h3 id="mainTitle">Enfoque Covariacional</h3>
                <button id="btnToggleMode" class="btn-toggle">Ver Correspondencia</button>
            </div>
            
            <!-- Controles Covariación -->
            <div id="panelCovariation" style="display: block;">
                <div class="header-text">
                    <p>Mueve los deslizadores para observar la compensación exacta entre los bidones.</p>
                </div>
                <div class="controls">
                    <div class="slider-group">
                        <label>Punto A (x): <span id="valA" class="label-val">2.0</span></label>
                        <input type="range" id="slideA" min="0" max="12" step="0.3" value="2">
                    </div>
                    <div class="slider-group">
                        <label>Punto B (x): <span id="valB" class="label-val">6.0</span></label>
                        <input type="range" id="slideB" min="0" max="12" step="0.3" value="6">
                    </div>
                </div>
                <div class="info-box info-covariation">
                    <strong>Análisis de Covariación:</strong>
                    Mientras <span class="text-blue">x varía <span id="dx">4.0</span></span> unidades, 
                    <span class="text-red">y varía exactamente <span id="dy">4.0</span></span> unidades en sentido opuesto.
                </div>
            </div>

            <!-- Controles Correspondencia -->
            <div id="panelCorrespondence" style="display: none;">
                <div class="header-text">
                    <p>Ingresa un valor para el bidón B y observa cómo se determina el valor del bidón A.</p>
                </div>
                <div class="controls">
                    <div style="display: flex; gap: 15px; align-items: center; width: 100%; justify-content: center;">
                        <label style="color: #475569; font-size: 0.95rem;">Valor de x (Bidón B):</label>
                        <input type="number" id="inputX" min="0" max="12" step="1" value="5">
                        <button id="btnAnimate" class="btn-action">Trazar Correspondencia</button>
                    </div>
                </div>
                <div class="info-box info-correspondence">
                    <strong>Análisis de Correspondencia:</strong>
                    Regla: <span class="mono-bg">y = 12 - x</span>. 
                    Para <span class="text-blue">x = <span id="corrX">5</span></span>, el valor asignado es <span class="text-green">y = <span id="corrY">7</span></span>.
                </div>
            </div>

            <div id="plot"></div>
        </div>
    </div>
</Layout>

<style>
    .recurso-wrapper {
        font-family: 'Inter', sans-serif;
        display: flex;
        justify-content: center;
        padding: 40px 20px;
        width: 100%;
        background-color: #f8fafc;
    }

    .card {
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        max-width: 800px; /* Cambiado de 850px a 800px */
        width: 100%;
    }

    .header-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e2e8f0;
        padding-bottom: 15px;
        margin-bottom: 20px;
    }

    #mainTitle { margin: 0; font-size: 1.5rem; color: #d32f2f; }

    .header-text { margin-bottom: 15px; text-align: left; }
    .header-text p { color: #64748b; font-size: 0.95rem; margin: 0; }

    .controls {
        display: flex;
        gap: 30px;
        background: #f1f5f9;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 15px;
        align-items: center;
        justify-content: space-around;
        min-height: 80px;
    }

    @media (max-width: 600px) {
        .controls { flex-direction: column; gap: 15px; }
        .header-actions { flex-direction: column; gap: 15px; align-items: flex-start; }
    }

    .slider-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex-grow: 1;
        width: 100%;
    }

    .slider-group label { color: #475569; font-size: 0.95rem; }
    .label-val { font-weight: 800; color: #1e293b; }
    
    input[type=range] { width: 100%; cursor: pointer; }
    input[type="number"] { padding: 8px; width: 70px; border: 1px solid #cbd5e1; border-radius: 4px; text-align: center; font-size: 1rem; }

    button { cursor: pointer; padding: 10px 18px; border: none; border-radius: 6px; font-weight: bold; transition: background 0.2s; font-size: 0.95rem; }
    .btn-toggle { background: #334155; color: white; }
    .btn-toggle:hover { background: #1e293b; }
    .btn-action { background: #16a34a; color: white; }
    .btn-action:hover { background: #15803d; }
    .btn-action:disabled { background: #94a3b8; cursor: not-allowed; }

    #plot { width: 100%; height: 550px; }

    .info-box {
        padding: 15px;
        font-size: 1rem;
        margin-top: 15px;
        border-radius: 4px;
        color: #1e293b;
    }
    
    .info-covariation { border-left: 4px solid #d32f2f; background: #fff1f2; }
    .info-correspondence { border-left: 4px solid #16a34a; background: #f0fdf4; }

    .text-blue { color: #2563eb; font-weight: 600; }
    .text-red { color: #d32f2f; font-weight: 600; }
    .text-green { color: #16a34a; font-weight: 600; }
    .mono-bg { font-family: monospace; background: #e2e8f0; padding: 2px 6px; border-radius: 4px; }
</style>

<script>
    declare const Plotly: any;

    const setupTriangulos = () => {
        // Nodos DOM
        const btnToggleMode = document.getElementById('btnToggleMode') as HTMLButtonElement | null;
        const mainTitle = document.getElementById('mainTitle') as HTMLElement | null;
        const panelCovariation = document.getElementById('panelCovariation') as HTMLElement | null;
        const panelCorrespondence = document.getElementById('panelCorrespondence') as HTMLElement | null;
        
        const slideA = document.getElementById('slideA') as HTMLInputElement | null;
        const slideB = document.getElementById('slideB') as HTMLInputElement | null;
        const valA = document.getElementById('valA') as HTMLElement | null;
        const valB = document.getElementById('valB') as HTMLElement | null;
        const dxText = document.getElementById('dx') as HTMLElement | null;
        const dyText = document.getElementById('dy') as HTMLElement | null;
        
        const inputX = document.getElementById('inputX') as HTMLInputElement | null;
        const btnAnimate = document.getElementById('btnAnimate') as HTMLButtonElement | null;
        const corrXText = document.getElementById('corrX') as HTMLElement | null;
        const corrYText = document.getElementById('corrY') as HTMLElement | null;
        
        const plotDiv = document.getElementById('plot') as HTMLElement | null;

        if (!slideA || !slideB || !inputX || !plotDiv || !btnToggleMode) return;

        // Estado del componente
        let currentMode = 'covariation';
        let animationId: number | null = null;

        // Estado guardado para edX
        let estadoEjercicio = {
    posA: slideA.value,
    posB: slideB.value,
    mode: 'covariation',
    inputX: inputX.value
};

        const layoutBase = {
            xaxis: { title: 'Litros en Bidón B (x)', range: [-0.5, 12.5], dtick: 1, gridcolor: '#e2e8f0' },
            yaxis: { 
                title: 'Litros en Bidón A (y)', 
                range: [-0.5, 12.5], 
                dtick: 1, 
                gridcolor: '#e2e8f0',
                scaleanchor: "x", 
                scaleratio: 1 
            },
            showlegend: false,
            margin: { t: 30, b: 40, l: 50, r: 20 },
            hovermode: false
        };

        const traceLineBase = {
            x: [0, 12], y: [12, 0],
            mode: 'lines', name: 'Recta',
            line: { color: '#94a3b8', width: 2, dash: 'dot' },
            hoverinfo: 'skip'
        };

        function renderCovariation() {
            const x1 = parseFloat(slideA!.value);
            const x2 = parseFloat(slideB!.value);
            const y1 = 12 - x1;
            const y2 = 12 - x2;

            valA!.innerText = x1.toFixed(1);
            valB!.innerText = x2.toFixed(1);
            
            const deltaX = x2 - x1;
            const deltaY = y2 - y1;
            dxText!.innerText = Math.abs(deltaX).toFixed(1);
            dyText!.innerText = Math.abs(deltaY).toFixed(1);

            estadoEjercicio.posA = x1.toString();
            estadoEjercicio.posB = x2.toString();

            const triangle = {
                x: [x1, x2, x2], y: [y1, y1, y2],
                mode: 'lines', fill: 'toself', fillcolor: 'rgba(211, 47, 47, 0.1)',
                line: { color: '#d32f2f', width: 3 }, name: 'Variación', hoverinfo: 'skip'
            };

            const points = {
                x: [x1, x2], y: [y1, y2],
                mode: 'markers+text', marker: { size: 12, color: '#1e293b' },
                text: [`A(${x1.toFixed(1)}, ${y1.toFixed(1)})`, `B(${x2.toFixed(1)}, ${y2.toFixed(1)})`],
                textposition: 'top center', hoverinfo: 'none'
            };

            const layout = { ...layoutBase, annotations: [
                { x: (x1 + x2) / 2, y: y1+0.7, text: `Δx = ${deltaX.toFixed(1)}`, showarrow: false, font: { color: '#2563eb', weight: 'bold' }, bgcolor: 'rgba(255,255,255,0.8)' },
                { x: x2+1, y: (y1 + y2) / 2, text: `Δy = ${deltaY.toFixed(1)}`, showarrow: false, font: { color: '#d32f2f', weight: 'bold' }, bgcolor: 'rgba(255,255,255,0.8)' }
            ]};

            if (typeof Plotly !== 'undefined') Plotly.react('plot', [traceLineBase, triangle, points], layout);
        }

        function resetCorrespondenceView(x: number, y: number) {
            corrXText!.innerText = x.toFixed(1);
            corrYText!.innerText = y.toFixed(1);
            estadoEjercicio.inputX = x.toString();
            if (typeof Plotly !== 'undefined') Plotly.react('plot', [traceLineBase], layoutBase);
        }

        function animateCorrespondence() {
            if (animationId) cancelAnimationFrame(animationId);
            btnAnimate!.disabled = true;

            let targetX = parseFloat(inputX!.value);
            if(targetX < 0) targetX = 0;
            if(targetX > 12) targetX = 12;
            inputX!.value = targetX.toString();
            estadoEjercicio.inputX = targetX.toString();

            const targetY = 12 - targetX;
            corrXText!.innerText = targetX.toFixed(1);
            corrYText!.innerText = targetY.toFixed(1);

            let currentX = targetX;
            let currentY = 0;
            let pathX = [targetX];
            let pathY = [0];
            
            const speed = 0.4; 
            let phase = targetY > 0 ? 1 : 2; 

            function step() {
                let complete = false;

                if (phase === 1) {
                    currentY += speed;
                    if (currentY >= targetY) {
                        currentY = targetY;
                        phase = targetX > 0 ? 2 : 3;
                    }
                    pathX.push(targetX);
                    pathY.push(currentY);
                } else if (phase === 2) {
                    currentX -= speed;
                    if (currentX <= 0) {
                        currentX = 0;
                        complete = true;
                    }
                    pathX.push(currentX);
                    pathY.push(targetY);
                } else {
                    complete = true;
                }

                const pathTrace = {
                    x: pathX, y: pathY,
                    mode: 'lines',
                    line: { color: '#16a34a', width: 3, dash: 'dash' },
                    hoverinfo: 'skip'
                };

                const pointTrace = {
                    x: [targetX], y: [targetY],
                    mode: 'markers+text',
                    marker: { size: 12, color: '#16a34a' },
                    text: [`(${targetX.toFixed(1)}, ${targetY.toFixed(1)})`],
                    textposition: 'top right',
                    hoverinfo: 'none'
                };

                Plotly.react('plot', [traceLineBase, pathTrace, pointTrace], layoutBase);

                if (!complete) {
                    animationId = requestAnimationFrame(step);
                } else {
                    const finalLayout = { ...layoutBase, annotations: [] as any[] };
                    
                    if (targetY > 0) {
                        finalLayout.annotations.push({
                            x: targetX, y: targetY, ax: targetX, ay: 0,
                            xref: 'x', yref: 'y', axref: 'x', ayref: 'y',
                            showarrow: true, arrowhead: 2, arrowcolor: '#16a34a', arrowwidth: 3
                        });
                    }
                    if (targetX > 0) {
                        finalLayout.annotations.push({
                            x: 0, y: targetY, ax: targetX, ay: targetY,
                            xref: 'x', yref: 'y', axref: 'x', ayref: 'y',
                            showarrow: true, arrowhead: 2, arrowcolor: '#16a34a', arrowwidth: 3
                        });
                    }

                    Plotly.react('plot', [traceLineBase, pointTrace], finalLayout);
                    btnAnimate!.disabled = false;
                }
            }
            
            Plotly.react('plot', [traceLineBase], layoutBase).then(() => {
                animationId = requestAnimationFrame(step);
            });
        }

        btnToggleMode!.addEventListener('click', () => {
            if (animationId) cancelAnimationFrame(animationId);
            if (btnAnimate) btnAnimate.disabled = false;

            if (currentMode === 'covariation') {
                currentMode = 'correspondence';
                estadoEjercicio.mode = 'correspondence';
                mainTitle!.innerText = 'Enfoque de Correspondencia';
                mainTitle!.style.color = '#16a34a';
                btnToggleMode!.innerText = 'Ver Covariación';
                panelCovariation!.style.display = 'none';
                panelCorrespondence!.style.display = 'block';
                
                const x = parseFloat(inputX!.value) || 5;
                resetCorrespondenceView(x, 12-x);
            } else {
                currentMode = 'covariation';
                estadoEjercicio.mode = 'covariation';
                mainTitle!.innerText = 'Enfoque Covariacional';
                mainTitle!.style.color = '#d32f2f';
                btnToggleMode!.innerText = 'Ver Correspondencia';
                panelCovariation!.style.display = 'block';
                panelCorrespondence!.style.display = 'none';
                renderCovariation();
            }
        });

        slideA!.addEventListener('input', renderCovariation);
        slideB!.addEventListener('input', renderCovariation);
        btnAnimate!.addEventListener('click', animateCorrespondence);

        const initPlot = () => {
            if (typeof Plotly !== 'undefined') {
                if (currentMode === 'covariation') {
                    renderCovariation();
                } else {
                    resetCorrespondenceView(parseFloat(inputX!.value) || 5, 12 - (parseFloat(inputX!.value) || 5));
                }
            } else {
                plotDiv!.innerHTML = "<p style='text-align:center; color:#64748b; margin-top:100px;'>Cargando motor gráfico...</p>";
                const checkPlotly = setInterval(() => {
                    if (typeof Plotly !== 'undefined') {
                        clearInterval(checkPlotly);
                        plotDiv!.innerHTML = "";
                        if (currentMode === 'covariation') {
                            renderCovariation();
                        } else {
                            resetCorrespondenceView(parseFloat(inputX!.value) || 5, 12 - (parseFloat(inputX!.value) || 5));
                        }
                    }
                }, 200);
            }
        };

        initPlot();

        // JSInput API
        (window as any).getGrade = () => JSON.stringify(estadoEjercicio);
        (window as any).getState = () => JSON.stringify(estadoEjercicio);
        (window as any).setState = (stateStr: string) => {
            if (!stateStr) return;
            try {
                const state = JSON.parse(stateStr);
                estadoEjercicio = state;
                
                if (state.posA) slideA!.value = state.posA;
                if (state.posB) slideB!.value = state.posB;
                if (state.inputX && inputX) inputX.value = state.inputX;
                
                if (state.mode === 'correspondence' && currentMode !== 'correspondence') {
                    currentMode = 'correspondence';
                    mainTitle!.innerText = 'Enfoque de Correspondencia';
                    mainTitle!.style.color = '#16a34a';
                    btnToggleMode!.innerText = 'Ver Covariación';
                    panelCovariation!.style.display = 'none';
                    panelCorrespondence!.style.display = 'block';
                    const x = parseFloat(inputX!.value) || 5;
                    resetCorrespondenceView(x, 12-x);
                } else if (state.mode !== 'correspondence' && currentMode !== 'covariation') {
                    currentMode = 'covariation';
                    mainTitle!.innerText = 'Enfoque Covariacional';
                    mainTitle!.style.color = '#d32f2f';
                    btnToggleMode!.innerText = 'Ver Correspondencia';
                    panelCovariation!.style.display = 'block';
                    panelCorrespondence!.style.display = 'none';
                    renderCovariation();
                } else {
                    if (currentMode === 'covariation') renderCovariation();
                }
            } catch(e) {
                console.error("Error restaurando estado en edX", e);
            }
        };
    };

    document.addEventListener('DOMContentLoaded', setupTriangulos);
    document.addEventListener('astro:page-load', setupTriangulos);
</script>
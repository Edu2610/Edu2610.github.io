---
import Layout from '../../../../layouts/Layout.astro';
---

<Layout titulo="Explorador Covariacional: Bidones">
    <div class="recurso-wrapper">
        <div class="card">
            <h2 class="card-title">Análisis Continuo: Traspaso de Jugo</h2>
            
            <div class="controls">
                <div class="slider-group">
                    <label>Cantidad de jugo vertida en el bidón B (x): <span id="valX" class="label-val">4.0</span> L</label>
                    <input type="range" id="slideX" min="0" max="12" step="0.1" value="4.0">
                </div>
            </div>

            <div class="info-box">
                <strong>Conservación del total:</strong>
                <span class="math-text">x + y = <span id="txtSumX">4.0</span> + <span id="txtSumY">8.0</span> = 12</span>
            </div>

            <div class="svg-container">
                <svg viewBox="0 0 460 370" id="plotSvg">
                    <g id="grid"></g>
                    
                    <line id="baseLine" stroke="#4A4A49" stroke-width="2" stroke-dasharray="5,5" />
                    <polygon id="dynTri" fill="rgba(232, 116, 97, 0.3)" stroke="#D33C31" stroke-width="2" />
                    
                    <circle id="startPoint" r="6" fill="#8B2E28" />
                    <text id="startText" font-size="13" fill="#4A4A49" font-weight="bold" text-anchor="end"></text>

                    <circle id="endPoint" r="6" fill="#8B2E28" />
                    <text id="endText" font-size="13" fill="#4A4A49" font-weight="bold" text-anchor="middle"></text>
                    
                    <text id="lblDx" fill="#D33C31" font-weight="bold" font-size="14"></text>
                    <text id="lblDy" fill="#8B2E28" font-weight="bold" font-size="14" alignment-baseline="middle"></text>
                    
                    <circle id="dynPt" r="7" fill="#D33C31" stroke="white" stroke-width="2" />
                    <text id="lblPt" fill="#D33C31" font-weight="bold" font-size="14"></text>
                    
                    <text id="labelX" font-size="15" fill="#4A4A49" text-anchor="middle" font-weight="bold">x</text>
                    <text id="labelY" font-size="15" fill="#4A4A49" text-anchor="middle" font-weight="bold">y</text>
                </svg>
            </div>
        </div>
    </div>
</Layout>

<style>
    :root {
        --red-main: #D33C31;
        --terracotta: #8B2E28;
        --red-light: #E87461;
        --grey-dark: #4A4A49;
        --bg-color: #F4F4F2;
    }

    .recurso-wrapper {
        font-family: 'Inter', system-ui, sans-serif; 
        background: var(--bg-color); 
        display: flex; 
        justify-content: center; 
        padding: 40px 20px; 
        width: 100%;
        box-sizing: border-box;
    }

    .card { 
        background: white; 
        padding: 30px; 
        border-radius: 12px; 
        box-shadow: 0 8px 25px rgba(0,0,0,0.06); 
        max-width: 750px; 
        width: 100%; 
        box-sizing: border-box; 
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .card-title { 
        color: var(--grey-dark); 
        margin: 0 0 20px 0; 
        font-size: 1.3rem; 
        font-weight: 700;
        width: 100%;
        text-align: left;
        border-bottom: 2px solid #e2e8f0; 
        padding-bottom: 15px; 
    }

    .controls { 
        width: 100%;
        background: var(--bg-color); 
        padding: 20px; 
        border-radius: 8px; 
        margin-bottom: 15px; 
        box-sizing: border-box;
    }

    .slider-group { 
        display: flex; 
        flex-direction: column; 
        gap: 10px; 
        width: 100%; 
    }

    .slider-group label {
        color: var(--grey-dark);
        font-weight: 600;
        font-size: 1rem;
    }

    .slider-group input { 
        width: 100%; 
        cursor: pointer; 
        accent-color: var(--red-main);
    }

    .label-val { 
        font-weight: 700; 
        color: var(--red-main); 
        font-size: 1.1rem; 
    }
    
    .info-box { 
        width: 100%;
        padding: 15px 20px; 
        border-radius: 6px; 
        margin-bottom: 20px; 
        box-sizing: border-box;
        border-left: 4px solid var(--terracotta); 
        background: rgba(232, 116, 97, 0.08); 
        color: var(--grey-dark);
    }

    .info-box strong {
        color: var(--terracotta);
        margin-bottom: 5px;
        display: block;
        font-size: 1.05rem;
    }

    .math-text { 
        font-family: 'Courier New', Courier, monospace; 
        font-weight: bold; 
        font-size: 1.1rem; 
        color: var(--grey-dark);
    }
    
    .svg-container { 
        width: 100%; 
        max-width: 460px; 
        display: block; 
        margin: 0 auto;
    }

    svg { 
        width: 100%; 
        height: auto; 
        overflow: visible; 
        font-family: 'Inter', sans-serif;
        user-select: none;
    }
</style>

<script>
    const setupCovariacion = () => {
        const COLS = {
            redMain: '#D33C31',
            terracotta: '#8B2E28',
            greyDark: '#4A4A49'
        };

        const slideX = document.getElementById('slideX') as HTMLInputElement | null;
        const valX = document.getElementById('valX') as HTMLElement | null;
        const txtSumX = document.getElementById('txtSumX') as HTMLElement | null;
        const txtSumY = document.getElementById('txtSumY') as HTMLElement | null;

        if (!slideX || !valX || !txtSumX || !txtSumY) return;

        let estadoEjercicio = { posX: slideX.value };

        const SVG_W = 460;
        const SVG_H = 370;
        const PAD = { l: 110, r: 60, t: 35, b: 45 }; 
        const PLOT_SIZE = 290; 
        const MAX_VAL = 12.5; 

        const mapX = (val: number) => PAD.l + (val / MAX_VAL) * PLOT_SIZE;
        const mapY = (val: number) => PAD.t + PLOT_SIZE - (val / MAX_VAL) * PLOT_SIZE;

        function buildGrid() {
            let gridHtml = '';
            const gridColor = COLS.greyDark;
            
            for (let i = 0; i <= 12; i++) {
                let px = mapX(i);
                let py = mapY(i);
                
                gridHtml += `<line x1="${px}" y1="${mapY(0)}" x2="${px}" y2="${mapY(MAX_VAL)}" stroke="${gridColor}" stroke-opacity="0.15" />`;
                gridHtml += `<line x1="${mapX(0)}" y1="${py}" x2="${mapX(MAX_VAL)}" y2="${py}" stroke="${gridColor}" stroke-opacity="0.15" />`;
                
                gridHtml += `<text x="${px}" y="${mapY(0) + 18}" font-size="12" fill="${gridColor}" fill-opacity="0.8" text-anchor="middle">${i}</text>`;
                gridHtml += `<text x="${mapX(0) - 10}" y="${py + 4}" font-size="12" fill="${gridColor}" fill-opacity="0.8" text-anchor="end">${i}</text>`;
            }
            document.getElementById('grid')!.innerHTML = gridHtml;

            const p0x = mapX(0), p0y = mapY(12);
            const p12x = mapX(12), p12y = mapY(0);
            
            const baseLine = document.getElementById('baseLine')!;
            baseLine.setAttribute('x1', p0x.toString()); baseLine.setAttribute('y1', p0y.toString());
            baseLine.setAttribute('x2', p12x.toString()); baseLine.setAttribute('y2', p12y.toString());
            
            const startPoint = document.getElementById('startPoint')!;
            startPoint.setAttribute('cx', p0x.toString()); startPoint.setAttribute('cy', p0y.toString());
            
            const startText = document.getElementById('startText')!;
            startText.setAttribute('x', (p0x - 8).toString()); 
            startText.setAttribute('y', (p0y - 10).toString());
            startText.textContent = "(0, 12)";

            const endPoint = document.getElementById('endPoint')!;
            endPoint.setAttribute('cx', p12x.toString()); 
            endPoint.setAttribute('cy', p12y.toString());

            const endText = document.getElementById('endText')!;
            endText.setAttribute('x', (p12x + 30).toString()); 
            endText.setAttribute('y', (p12y + 10).toString());
            endText.textContent = "(12, 0)";

            document.getElementById('labelX')!.setAttribute('x', (PAD.l + PLOT_SIZE / 2).toString());
            document.getElementById('labelX')!.setAttribute('y', (SVG_H - 10).toString());
            document.getElementById('labelY')!.setAttribute('x', (PAD.l - 45).toString());
            document.getElementById('labelY')!.setAttribute('y', (PAD.t + PLOT_SIZE / 2).toString());
        }

        function updatePlot() {
            let x = parseFloat(slideX!.value);
            let y = 12 - x;
            let dx = x;
            let dy = y - 12;

            valX!.innerText = x.toFixed(1);
            txtSumX!.innerText = x.toFixed(1);
            txtSumY!.innerText = y.toFixed(1);

            const px0 = mapX(0);
            const py12 = mapY(12);
            const pxx = mapX(x);
            const pyy = mapY(y);

            const dynTri = document.getElementById('dynTri')!;
            if (x > 0) {
                dynTri.setAttribute('points', `${px0},${py12} ${pxx},${py12} ${pxx},${pyy}`);
                dynTri.style.display = "block";
            } else {
                dynTri.style.display = "none";
            }

            const lblDx = document.getElementById('lblDx')!;
            const lblDy = document.getElementById('lblDy')!;
            if (x > 0) {
                lblDx.setAttribute('y', (py12 - 10).toString()); 
                lblDx.textContent = `Δx = ${dx.toFixed(1)}`;
                
                if (x < 2) {
                    lblDx.setAttribute('x', (px0 + 10).toString());
                    lblDx.setAttribute('text-anchor', 'start');
                } else {
                    lblDx.setAttribute('x', mapX(x / 2).toString());
                    lblDx.setAttribute('text-anchor', 'middle');
                }

                lblDy.setAttribute('x', (pxx + 10).toString()); 
                lblDy.setAttribute('y', mapY(12 + dy / 2).toString());
                lblDy.textContent = `Δy = ${dy.toFixed(1)}`;
            } else {
                lblDx.textContent = "";
                lblDy.textContent = "";
            }

            document.getElementById('dynPt')!.setAttribute('cx', pxx.toString());
            document.getElementById('dynPt')!.setAttribute('cy', pyy.toString());
            
            const lblPt = document.getElementById('lblPt')!;
            lblPt.textContent = `(${x.toFixed(1)}, ${y.toFixed(1)})`;
            lblPt.setAttribute('x', (pxx + 12).toString());
            lblPt.setAttribute('y', (pyy - 5).toString());
            lblPt.setAttribute('text-anchor', 'start');
        }

        slideX.addEventListener('input', () => {
            updatePlot();
            estadoEjercicio.posX = slideX!.value;
        });

        buildGrid();
        updatePlot();

        // JSInput API de edX
        (window as any).getGrade = () => JSON.stringify(estadoEjercicio);
        (window as any).getState = () => JSON.stringify(estadoEjercicio);
        (window as any).setState = (stateStr: string) => {
            if (!stateStr) return;
            try {
                const state = JSON.parse(stateStr);
                estadoEjercicio = state;
                
                if (state.posX) {
                    slideX!.value = state.posX;
                    updatePlot();
                }
            } catch(e) {
                console.error("Error restaurando estado en edX", e);
            }
        };
    };

    document.addEventListener('DOMContentLoaded', setupCovariacion);
    document.addEventListener('astro:page-load', setupCovariacion);
</script>
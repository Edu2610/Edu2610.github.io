---
import Layout from '../../../../layouts/Layout.astro';
---

<Layout titulo="Doble Recta Numérica">
    <div class="recurso-wrapper">
        <div class="card">
            <div class="controls">
                <button id="btnVerify" class="btn-verify">Comprobar paso</button>
            </div>

            <div id="svg-container">
                <svg width="100%" height="100%" viewBox="0 0 800 450">
                    <defs>
                        <marker id="arrow-blue" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#2563eb" />
                        </marker>
                        <marker id="arrow-red" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#d32f2f" />
                        </marker>
                    </defs>

                    <line x1="80" y1="150" x2="760" y2="150" stroke="#94a3b8" stroke-width="3" />
                    <line x1="80" y1="280" x2="760" y2="280" stroke="#94a3b8" stroke-width="3" />
                    
                    <text x="75" y="155" font-weight="bold" fill="#1e293b" text-anchor="end">Tiempo (x)</text>
                    <text x="75" y="285" font-weight="bold" fill="#1e293b" text-anchor="end">Litros (y)</text>

                    <line x1="120" y1="140" x2="120" y2="290" stroke="#cbd5e1" stroke-width="2" stroke-dasharray="4" />
                    <text x="120" y="130" text-anchor="middle" font-size="14">0</text>
                    <text x="120" y="310" text-anchor="middle" font-size="14">0</text>

                    <line x1="660" y1="140" x2="660" y2="290" stroke="#1e293b" stroke-width="2" stroke-dasharray="4" />
                    <circle cx="660" cy="150" r="6" fill="#1e293b" />
                    <circle cx="660" cy="280" r="6" fill="#1e293b" />
                    <text x="660" y="130" text-anchor="middle" font-weight="bold" font-size="16">9</text>
                    <text x="660" y="310" text-anchor="middle" font-weight="bold" font-size="16">6</text>

                    <g id="step1-arrows">
                        <path d="M 650 110 Q 420 10 190 110" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                        <foreignObject x="395" y="10" width="50" height="30">
                            <input type="text" id="div-x" placeholder="÷ ?" class="input-box blue-border" autocomplete="off">
                        </foreignObject>
                        <foreignObject x="455" y="10" width="40" height="30" id="corr-div-x" class="hidden">
                            <div class="correction-box">9</div>
                        </foreignObject>

                        <path d="M 650 320 Q 420 420 190 320" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                        <foreignObject x="395" y="390" width="50" height="30">
                            <input type="text" id="div-y" placeholder="÷ ?" class="input-box red-border" autocomplete="off">
                        </foreignObject>
                        <foreignObject x="455" y="390" width="40" height="30" id="corr-div-y" class="hidden">
                            <div class="correction-box">9</div>
                        </foreignObject>
                    </g>

                    <g id="step1-results" class="hidden">
                        <line x1="180" y1="140" x2="180" y2="290" stroke="#059669" stroke-width="2" stroke-dasharray="4" />
                        <circle cx="180" cy="150" r="6" fill="#059669" />
                        <circle cx="180" cy="280" r="6" fill="#059669" />
                        <text x="180" y="130" text-anchor="middle" font-weight="bold" font-size="16" fill="#059669">1</text>
                        <text x="180" y="310" text-anchor="middle" font-weight="bold" font-size="16" fill="#059669">2/3</text>
                    </g>

                    <g id="step2-arrows" class="hidden">
                        <line x1="570" y1="140" x2="570" y2="290" stroke="#9333ea" stroke-width="2" stroke-dasharray="4" />
                        <circle cx="570" cy="150" r="6" fill="#9333ea" />
                        <circle cx="570" cy="280" r="6" fill="#9333ea" />

                        <path d="M 190 120 Q 365 60 535 120" fill="none" stroke="#2563eb" stroke-width="2" marker-end="url(#arrow-blue)" />
                        <text x="355" y="120" text-anchor="middle" font-weight="bold" fill="#2563eb">× 7.5</text>

                        <path d="M 190 310 Q 365 370 535 310" fill="none" stroke="#d32f2f" stroke-width="2" marker-end="url(#arrow-red)" />
                        <text x="355" y="320" text-anchor="middle" font-weight="bold" fill="#d32f2f">× 7.5</text>

                        <foreignObject x="545" y="100" width="50" height="30">
                            <input type="text" id="final-x" placeholder="?" class="input-box purple-border" autocomplete="off">
                        </foreignObject>
                        <foreignObject x="605" y="100" width="40" height="30" id="corr-final-x" class="hidden">
                            <div class="correction-box">7.5</div>
                        </foreignObject>
                        
                        <foreignObject x="545" y="295" width="50" height="30">
                            <input type="text" id="final-y" placeholder="?" class="input-box purple-border" autocomplete="off">
                        </foreignObject>
                        <foreignObject x="605" y="295" width="40" height="30" id="corr-final-y" class="hidden">
                            <div class="correction-box">5</div>
                        </foreignObject>
                    </g>
                </svg>
            </div>
        </div>
    </div>
</Layout>

<style>
    .recurso-wrapper {
        font-family: 'Inter', sans-serif;
        display: flex;
        justify-content: center;
        padding: 40px 20px;
        width: 100%;
        box-sizing: border-box;
    }

    .card { 
        background: white; 
        padding: 20px; 
        border-radius: 12px; 
        box-shadow: 0 4px 20px rgba(0,0,0,0.08); 
        max-width: 850px; 
        width: 100%; 
    }

    .controls { 
        display: flex; 
        gap: 10px; 
        background: #f1f5f9; 
        padding: 15px; 
        border-radius: 8px; 
        margin-bottom: 20px; 
        justify-content: center;
    }

    button { 
        padding: 8px 24px; 
        border: none; 
        border-radius: 6px; 
        font-weight: bold; 
        cursor: pointer; 
        transition: background 0.2s; 
        color: white; 
    }
    
    .btn-verify { background: #2563eb; }
    .btn-verify:hover:not(:disabled) { background: #1d4ed8; }
    .btn-verify:disabled { background: #cbd5e1; cursor: not-allowed; }
    
    #svg-container { width: 100%; height: 450px; position: relative; }
    text { font-family: sans-serif; }
    
    .hidden { opacity: 0; pointer-events: none; }
    .visible { opacity: 1; transition: opacity 0.5s ease-in; }
    
    .input-box {
        width: 100%; height: 100%;
        text-align: center;
        font-weight: bold; font-size: 14px;
        border: 2px solid; border-radius: 4px;
        box-sizing: border-box;
        outline: none;
        background: white;
        transition: all 0.3s;
    }

    .blue-border { border-color: #2563eb; color: #2563eb; }
    .red-border { border-color: #d32f2f; color: #d32f2f; }
    .purple-border { border-color: #9333ea; color: #9333ea; }
    
    .input-box:focus { box-shadow: 0 0 5px rgba(0,0,0,0.2); }
    .input-box.correct { background-color: #dcfce7; border-color: #059669 !important; color: #059669; }
    .input-box.incorrect { background-color: #fef2f2; border-color: #ef4444 !important; color: #b91c1c; text-decoration: line-through; opacity: 0.7; }
    
    .correction-box { 
        background: #dcfce7; 
        color: #059669; 
        border: 2px dashed #059669; 
        border-radius: 4px; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        font-weight: bold; 
        font-size: 14px; 
        width: 100%; 
        height: 100%; 
        box-sizing: border-box; 
    }

    .input-box:disabled { cursor: default; }

    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-5px); }
        75% { transform: translateX(5px); }
    }
    .error { border-color: #ef4444 !important; animation: shake 0.3s; }
</style>

<script>
    const setupDobleRecta = () => {
        const originalBtnVerify = document.getElementById('btnVerify') as HTMLButtonElement | null;
        if (!originalBtnVerify) return;

        // Clonar botón para evitar acumulación de eventos en Astro
        const btnVerify = originalBtnVerify.cloneNode(true) as HTMLButtonElement;
        originalBtnVerify.parentNode?.replaceChild(btnVerify, originalBtnVerify);

        const inputIds = ['div-x', 'div-y', 'final-x', 'final-y'];
        const inputs: Record<string, HTMLInputElement> = {};

        // Clonar inputs
        inputIds.forEach(id => {
            const el = document.getElementById(id) as HTMLInputElement | null;
            if (el) {
                const clone = el.cloneNode(true) as HTMLInputElement;
                el.parentNode?.replaceChild(clone, el);
                inputs[id] = clone;
            }
        });

        const divX = inputs['div-x'];
        const divY = inputs['div-y'];
        const finalX = inputs['final-x'];
        const finalY = inputs['final-y'];

        // Elementos estáticos de retroalimentación
        const corrDivX = document.getElementById('corr-div-x');
        const corrDivY = document.getElementById('corr-div-y');
        const corrFinalX = document.getElementById('corr-final-x');
        const corrFinalY = document.getElementById('corr-final-y');
        const step1Results = document.getElementById('step1-results');
        const step2Arrows = document.getElementById('step2-arrows');

        let estadoInteractivo = {
            divX: "", divY: "", finalX: "", finalY: "",
            statusDivX: "", statusDivY: "", statusFinalX: "", statusFinalY: "",
            currentStep: 1
        };

        Object.values(inputs).forEach(input => {
            input.addEventListener('input', (e) => {
                const el = e.target as HTMLInputElement;
                el.classList.remove('incorrect', 'correct', 'error'); 
                
                const id = el.id;
                const val = el.value.trim();
                if (id === 'div-x') estadoInteractivo.divX = val;
                if (id === 'div-y') estadoInteractivo.divY = val;
                if (id === 'final-x') estadoInteractivo.finalX = val;
                if (id === 'final-y') estadoInteractivo.finalY = val;
            });
        });

        function isValidInput(val: string) {
            const str = val.trim().replace(',', '.');
            if (str === '') return false;
            const num = Number(str);
            if (isNaN(num)) return false;
            if (num <= 0) return false;
            return true;
        }

        function showError(element: HTMLElement) {
            element.classList.add('error');
            setTimeout(() => element.classList.remove('error'), 300);
        }

        function aplicarEstadoVisual() {
            if (!step1Results || !step2Arrows || !corrDivX || !corrDivY || !corrFinalX || !corrFinalY) return;

            if (estadoInteractivo.currentStep >= 2) {
                divX.disabled = true; divX.value = estadoInteractivo.divX;
                divY.disabled = true; divY.value = estadoInteractivo.divY;
                
                if (estadoInteractivo.statusDivX === 'correct') {
                    divX.classList.add('correct');
                    corrDivX.classList.replace('visible', 'hidden');
                } else if (estadoInteractivo.statusDivX === 'incorrect') {
                    divX.classList.add('incorrect');
                    corrDivX.classList.replace('hidden', 'visible');
                }

                if (estadoInteractivo.statusDivY === 'correct') {
                    divY.classList.add('correct');
                    corrDivY.classList.replace('visible', 'hidden');
                } else if (estadoInteractivo.statusDivY === 'incorrect') {
                    divY.classList.add('incorrect');
                    corrDivY.classList.replace('hidden', 'visible');
                }
                
                step1Results.classList.replace('hidden', 'visible');
                step2Arrows.classList.replace('hidden', 'visible');
            } else {
                divX.disabled = false; divY.disabled = false;
                divX.classList.remove('correct', 'incorrect'); divY.classList.remove('correct', 'incorrect');
                corrDivX.classList.replace('visible', 'hidden'); corrDivY.classList.replace('visible', 'hidden');
                step1Results.classList.replace('visible', 'hidden'); step2Arrows.classList.replace('visible', 'hidden');
            }

            if (estadoInteractivo.currentStep === 3) {
                finalX.disabled = true; finalX.value = estadoInteractivo.finalX;
                finalY.disabled = true; finalY.value = estadoInteractivo.finalY;

                if (estadoInteractivo.statusFinalX === 'correct') {
                    finalX.classList.add('correct');
                    corrFinalX.classList.replace('visible', 'hidden');
                } else if (estadoInteractivo.statusFinalX === 'incorrect') {
                    finalX.classList.add('incorrect');
                    corrFinalX.classList.replace('hidden', 'visible');
                }

                if (estadoInteractivo.statusFinalY === 'correct') {
                    finalY.classList.add('correct');
                    corrFinalY.classList.replace('visible', 'hidden');
                } else if (estadoInteractivo.statusFinalY === 'incorrect') {
                    finalY.classList.add('incorrect');
                    corrFinalY.classList.replace('hidden', 'visible');
                }
                
                btnVerify.disabled = true;
            } else {
                finalX.disabled = false; finalY.disabled = false;
                finalX.classList.remove('correct', 'incorrect'); finalY.classList.remove('correct', 'incorrect');
                corrFinalX.classList.replace('visible', 'hidden'); corrFinalY.classList.replace('visible', 'hidden');
                if (estadoInteractivo.currentStep === 2) btnVerify.disabled = false;
            }
        }

        btnVerify.addEventListener('click', () => {
            if (estadoInteractivo.currentStep === 1) {
                const validX = isValidInput(estadoInteractivo.divX);
                const validY = isValidInput(estadoInteractivo.divY);

                if (!validX) showError(divX);
                if (!validY) showError(divY);

                if (validX && validY) {
                    estadoInteractivo.statusDivX = (estadoInteractivo.divX === '9') ? 'correct' : 'incorrect';
                    estadoInteractivo.statusDivY = (estadoInteractivo.divY === '9') ? 'correct' : 'incorrect';
                    
                    estadoInteractivo.currentStep = 2;
                    aplicarEstadoVisual();
                }
                
            } else if (estadoInteractivo.currentStep === 2) {
                const validX = isValidInput(estadoInteractivo.finalX);
                const validY = isValidInput(estadoInteractivo.finalY);

                if (!validX) showError(finalX);
                if (!validY) showError(finalY);

                if (validX && validY) {
                    const fX = estadoInteractivo.finalX.replace(',', '.');
                    const fY = estadoInteractivo.finalY.replace(',', '.');

                    estadoInteractivo.statusFinalX = (fX === '7.5') ? 'correct' : 'incorrect';
                    estadoInteractivo.statusFinalY = (fY === '5') ? 'correct' : 'incorrect';

                    estadoInteractivo.currentStep = 3;
                    aplicarEstadoVisual();
                }
            }
        });

        // Exponer APIs para edX
        (window as any).getGrade = () => JSON.stringify(estadoInteractivo);
        (window as any).getState = () => JSON.stringify(estadoInteractivo);
        (window as any).setState = (stateStr: string) => {
            if (!stateStr) return;
            try {
                const parsed = JSON.parse(stateStr);
                estadoInteractivo = Object.assign(estadoInteractivo, parsed);
                aplicarEstadoVisual();
            } catch(e) {
                console.error("Error restaurando estado en edX", e);
            }
        };
    };

    document.addEventListener('DOMContentLoaded', setupDobleRecta);
    document.addEventListener('astro:page-load', setupDobleRecta);
</script>